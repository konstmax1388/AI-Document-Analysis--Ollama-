Функция ПервыйИдентификаторИзОчередиОжидания()

	// Учитываем только актуальный статус заявки (последняя запись по Идентификатору), иначе после смены
	// статуса на «Выполняется» старая строка «Ожидает» остаётся в регистре и ломает порядок очереди.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	АктуальныеОжидающие.Идентификатор КАК Идентификатор
	|ИЗ
	|	(ВЫБРАТЬ
	|		Срез.Идентификатор КАК Идентификатор,
	|		Срез.Статус КАК Статус,
	|		Постановка.ДатаВремяПостановки КАК ДатаВремяПостановки
	|	ИЗ
	|		(ВЫБРАТЬ
	|			Очередь.Идентификатор КАК Идентификатор,
	|			МАКСИМУМ(Очередь.ДатаВремя) КАК ДатаВремяПоследнейЗаписи
	|		ИЗ
	|			РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК Очередь
	|		СГРУППИРОВАТЬ ПО
	|			Очередь.Идентификатор) КАК КлючиПоследнейЗаписи
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК Срез
	|			ПО КлючиПоследнейЗаписи.Идентификатор = Срез.Идентификатор
	|				И КлючиПоследнейЗаписи.ДатаВремяПоследнейЗаписи = Срез.ДатаВремя
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				Очередь.Идентификатор КАК Идентификатор,
	|				МИНИМУМ(Очередь.ДатаВремя) КАК ДатаВремяПостановки
	|			ИЗ
	|				РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК Очередь
	|			СГРУППИРОВАТЬ ПО
	|				Очередь.Идентификатор) КАК Постановка
	|			ПО Срез.Идентификатор = Постановка.Идентификатор
	|	ГДЕ
	|		Срез.Статус = ""Ожидает"") КАК АктуальныеОжидающие
	|
	|УПОРЯДОЧИТЬ ПО
	|	АктуальныеОжидающие.ДатаВремяПостановки";

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Строка(Выборка.Идентификатор);
	КонецЕсли;

	Возврат "";

КонецФункции

Процедура ОбновитьСтатусОчередиРаспознавания(
	Знач ИдентификаторОчереди,
	Знач ДокументСсылка,
	Знач ФайлСсылка,
	Знач Статус,
	Знач Сообщение)

	НаборЗаписей = РегистрыСведений.ИАДО_ОчередьРаспознаванияФайлов.СоздатьНаборЗаписей();
	Запись = НаборЗаписей.Добавить();
	Запись.ДатаВремя = ТекущаяУниверсальнаяДата();
	Запись.Идентификатор = ИдентификаторОчереди;
	Запись.Статус = Лев(Статус, 20);
	Запись.Файл = ФайлСсылка;
	Запись.Документ = ДокументСсылка;
	Запись.Сообщение = Лев(Строка(Сообщение), 512);
	НаборЗаписей.Записать(Ложь);

КонецПроцедуры

Процедура ИАДО_ЗаписатьСобытиеОчередиВЖурналИИ(Знач ПараметрыСобытия)

	ПарамЖурнал = Новый Структура;
	ПарамЖурнал.Вставить("ВидОперации", ПараметрыСобытия.ВидОперации);
	ПарамЖурнал.Вставить("Успешно", ПараметрыСобытия.Успешно);
	ПарамЖурнал.Вставить("Сообщение", ПараметрыСобытия.Сообщение);
	Если ПараметрыСобытия.Свойство("Документ") Тогда
		ПарамЖурнал.Вставить("Документ", ПараметрыСобытия.Документ);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("Файл") Тогда
		ПарамЖурнал.Вставить("Файл", ПараметрыСобытия.Файл);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("Детали") Тогда
		ПарамЖурнал.Вставить("Детали", ПараметрыСобытия.Детали);
	КонецЕсли;

	ИАДО_ЖурналИИВызовСервера.ДобавитьЗапись(ПарамЖурнал);

КонецПроцедуры

#КонецОбласти

#КонецЕсли
