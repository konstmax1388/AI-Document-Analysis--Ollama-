// Ставит заявку в регистр очереди распознавания перед анализом ИИ.
//
Функция ПоставитьВОчередьРаспознавания(Знач ФайлСсылка, Знач ДокументСсылка) Экспорт

	Идентификатор = Строка(Новый УникальныйИдентификатор());
	НаборЗаписей = РегистрыСведений.ИАДО_ОчередьРаспознаванияФайлов.СоздатьНаборЗаписей();
	Запись = НаборЗаписей.Добавить();
	Запись.ДатаВремя = ТекущаяУниверсальнаяДата();
	Запись.Идентификатор = Идентификатор;
	Запись.Статус = "Ожидает";
	Запись.Файл = ФайлСсылка;
	Запись.Документ = ДокументСсылка;
	Запись.Сообщение = "";
	НаборЗаписей.Записать(Ложь);

	ПарамСобытияЖурнала = Новый Структура;
	ПарамСобытияЖурнала.Вставить("ВидОперации", "РаспознаваниеОчередь");
	ПарамСобытияЖурнала.Вставить("Успешно", Истина);
	ПарамСобытияЖурнала.Вставить("Сообщение", НСтр("ru = 'Файл поставлен в очередь распознавания'"));
	ПарамСобытияЖурнала.Вставить("Документ", ДокументСсылка);
	ПарамСобытияЖурнала.Вставить("Файл", ФайлСсылка);
	ПарамСобытияЖурнала.Вставить("Детали", Новый Структура("ИдентификаторОчереди", Идентификатор));
	ИАДО_ЗаписатьСобытиеОчередиВЖурналИИ(ПарамСобытияЖурнала);

	Возврат Идентификатор;

КонецФункции

// Ожидает своей очереди с лимитом ЛимитОжиданияСвоейОчередиМиллисекунд() (5 минут).
//
Функция ДождатьсяСвоейОчередиРаспознавания(Знач ИдентификаторОчереди, Знач ДокументСсылка, Знач ФайлСсылка) Экспорт

	МаксОжиданиеМс = ЛимитОжиданияСвоейОчередиМиллисекунд();
	ИнтервалОпросаСек = 2;
	ВремяНачалаОжидания = ТекущаяУниверсальнаяДатаВМиллисекундах();

	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачалаОжидания <= МаксОжиданиеМс Цикл

		ИдентификаторПервойЗаявки = ПервыйИдентификаторИзОчередиОжидания();
		Если ПустаяСтрока(ИдентификаторПервойЗаявки) Тогда
			ОбщегоНазначенияБТС.Пауза(ИнтервалОпросаСек);
			Продолжить;
		КонецЕсли;

		Если ИдентификаторПервойЗаявки = ИдентификаторОчереди Тогда
			ОбновитьСтатусОчередиРаспознавания(
				ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Выполняется", "");
			Возврат Истина;
		КонецЕсли;

		ОбщегоНазначенияБТС.Пауза(ИнтервалОпросаСек);

	КонецЦикла;

	Возврат Ложь;

КонецФункции

// Добавляет строку завершения/ошибки в регистр очереди.
//
Процедура ЗавершитьОчередьРаспознавания(
	Знач ИдентификаторОчереди,
	Знач ДокументСсылка,
	Знач ФайлСсылка,
	Знач Статус,
	Знач Сообщение) Экспорт

	ОбновитьСтатусОчередиРаспознавания(ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, Статус, Сообщение);

КонецПроцедуры

// Истина, если по паре документ+файл последняя запись очереди в статусе «Ожидает» или «Выполняется».
//
Функция ОчередьРаспознаванияИАДОАктивна(Знач ДокументСсылка, Знач ФайлСсылка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Очередь.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК Очередь
	|ГДЕ
	|	Очередь.Документ = &Документ
	|	И Очередь.Файл = &Файл
	|УПОРЯДОЧИТЬ ПО
	|	Очередь.ДатаВремя УБЫВ";

	Запрос.УстановитьПараметр("Документ", ДокументСсылка);
	Запрос.УстановитьПараметр("Файл", ФайлСсылка);

	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	СтатусОчереди = СокрЛП(Строка(Выборка.Статус));

	Возврат СтатусОчереди = "Ожидает" Или СтатусОчереди = "Выполняется";

КонецФункции

// Сводка по актуальным статусам заявок (последняя запись по каждому идентификатору).
//
// Возвращаемое значение:
//  Структура — поля: ТекстСводки (Строка), Ожидает, Выполняется, Завершено, Ошибка, ВсегоАктивных (Число).
//
Функция СводкаПоОчередиРаспознавания() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Срез.Статус КАК Статус,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Срез.Идентификатор) КАК Количество
	|ИЗ
	|	(ВЫБРАТЬ
	|		СрезВнутр.Идентификатор КАК Идентификатор,
	|		СрезВнутр.Статус КАК Статус
	|	ИЗ
	|		(ВЫБРАТЬ
	|			Очередь.Идентификатор КАК Идентификатор,
	|			МАКСИМУМ(Очередь.ДатаВремя) КАК ДатаВремяПоследнейЗаписи
	|		ИЗ
	|			РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК Очередь
	|		СГРУППИРОВАТЬ ПО
	|			Очередь.Идентификатор) КАК КлючиПоследнейЗаписи
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК СрезВнутр
	|			ПО КлючиПоследнейЗаписи.Идентификатор = СрезВнутр.Идентификатор
	|				И КлючиПоследнейЗаписи.ДатаВремяПоследнейЗаписи = СрезВнутр.ДатаВремя) КАК Срез
	|
	|СГРУППИРОВАТЬ ПО
	|	Срез.Статус";

	РезультатЗапроса = Запрос.Выполнить();
	Таблица = РезультатЗапроса.Выгрузить();

	Ожидает = 0;
	Выполняется = 0;
	Завершено = 0;
	Ошибка = 0;

	Для Каждого СтрокаТаблицы Из Таблица Цикл

		Статус = СокрЛП(Строка(СтрокаТаблицы.Статус));
		Количество = СтрокаТаблицы.Количество;

		Если Статус = "Ожидает" Тогда
			Ожидает = Количество;
		ИначеЕсли Статус = "Выполняется" Тогда
			Выполняется = Количество;
		ИначеЕсли Статус = "Завершено" Тогда
			Завершено = Количество;
		ИначеЕсли Статус = "Ошибка" Тогда
			Ошибка = Количество;
		КонецЕсли;

	КонецЦикла;

	ВсегоАктивных = Ожидает + Выполняется;

	ТекстСводки =
		НСтр("ru = 'Ожидает:'") + " " + Формат(Ожидает, "ЧН=0; ЧГ=") + Символы.ПС
		+ НСтр("ru = 'Выполняется:'") + " " + Формат(Выполняется, "ЧН=0; ЧГ=") + Символы.ПС
		+ НСтр("ru = 'Завершено:'") + " " + Формат(Завершено, "ЧН=0; ЧГ=") + Символы.ПС
		+ НСтр("ru = 'Ошибка:'") + " " + Формат(Ошибка, "ЧН=0; ЧГ=") + Символы.ПС
		+ НСтр("ru = 'Активных (ожидает+выполняется):'") + " " + Формат(ВсегоАктивных, "ЧН=0; ЧГ=");

	Результат = Новый Структура;
	Результат.Вставить("ТекстСводки", ТекстСводки);
	Результат.Вставить("Ожидает", Ожидает);
	Результат.Вставить("Выполняется", Выполняется);
	Результат.Вставить("Завершено", Завершено);
	Результат.Вставить("Ошибка", Ошибка);
	Результат.Вставить("ВсегоАктивных", ВсегоАктивных);

	Возврат Результат;

КонецФункции

// Сбрасывает заявки в статусах «Ожидает»/«Выполняется», у которых последняя запись старше 15 минут.
//
// Возвращаемое значение:
//  Число — количество сброшенных идентификаторов.
//
Функция СброситьЗависшиеЗаявкиОчередиРаспознавания() Экспорт

	ПорогМс = ПорогЗависшейЗаявкиМиллисекунд();
	ГраницаУниверсальная = ТекущаяУниверсальнаяДата() - ПорогМс / 1000;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Срез.Идентификатор КАК Идентификатор,
	|	Срез.Документ КАК Документ,
	|	Срез.Файл КАК Файл
	|ИЗ
	|	(ВЫБРАТЬ
	|		СрезВнутр.Идентификатор КАК Идентификатор,
	|		СрезВнутр.Статус КАК Статус,
	|		СрезВнутр.ДатаВремя КАК ДатаВремяПоследней,
	|		СрезВнутр.Документ КАК Документ,
	|		СрезВнутр.Файл КАК Файл
	|	ИЗ
	|		(ВЫБРАТЬ
	|			Очередь.Идентификатор КАК Идентификатор,
	|			МАКСИМУМ(Очередь.ДатаВремя) КАК ДатаВремяПоследнейЗаписи
	|		ИЗ
	|			РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК Очередь
	|		СГРУППИРОВАТЬ ПО
	|			Очередь.Идентификатор) КАК КлючиПоследнейЗаписи
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов КАК СрезВнутр
	|			ПО КлючиПоследнейЗаписи.Идентификатор = СрезВнутр.Идентификатор
	|				И КлючиПоследнейЗаписи.ДатаВремяПоследнейЗаписи = СрезВнутр.ДатаВремя) КАК Срез
	|ГДЕ
	|	(Срез.Статус = ""Ожидает""
	|			ИЛИ Срез.Статус = ""Выполняется"")
	|	И Срез.ДатаВремяПоследней < &Граница";

	Запрос.УстановитьПараметр("Граница", ГраницаУниверсальная);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	КоличествоСброшенных = 0;
	ТекстСообщения = НСтр("ru = 'Сброшено администратором: зависшая заявка (старше 15 мин)'");

	Пока Выборка.Следующий() Цикл

		ОбновитьСтатусОчередиРаспознавания(
			Выборка.Идентификатор,
			Выборка.Документ,
			Выборка.Файл,
			"Ошибка",
			ТекстСообщения);
		КоличествоСброшенных = КоличествоСброшенных + 1;

	КонецЦикла;

	Возврат КоличествоСброшенных;

КонецФункции

