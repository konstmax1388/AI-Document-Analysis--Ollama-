
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Формирует DOCX с текстом ответа модели и добавляет файл в карточку документа предприятия.
//
// Параметры:
//  ДокументСсылка - СправочникСсылка.ДокументыПредприятия - владелец файла;
//  ФайлИсходный - СправочникСсылка.Файлы - анализируемый файл (для имени вложения);
//  ТекстОтвета - Строка - полный текст ответа модели.
//
Процедура СоздатьФайлОтветаИИПоДокументу(
	Знач ДокументСсылка,
	Знач ФайлИсходный,
	Знач ТекстОтвета) Экспорт

	Если Не ЗначениеЗаполнено(ДокументСсылка) Тогда
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(СокрЛП(ТекстОтвета)) Тогда
		Возврат;
	КонецЕсли;

	ИмяИсходного = "";
	Если ЗначениеЗаполнено(ФайлИсходный) Тогда
		ИмяИсходного = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФайлИсходный, "Наименование");
	КонецЕсли;

	ИмяИсходного = СокрЛП(Строка(ИмяИсходного));
	ИмяИсходного = ИАДО_СанитизироватьИмяФайлаДляВложения(ИмяИсходного);
	Если ПустаяСтрока(ИмяИсходного) Тогда
		ИмяИсходного = НСтр("ru = 'Файл'");
	КонецЕсли;

	ОсноваИмени = ИмяИсходного + " - " + НСтр("ru = 'ответ ИИ'");
	МеткаВремени = Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-dd_HHmmss");
	ИмяБезРасширения = Лев(ОсноваИмени + " " + МеткаВремени, 180);

	ДвоичныеДанныеDocx = ИАДО_СобратьДвоичныеДанныеDocxПоТексту(ТекстОтвета);
	Если ДвоичныеДанныеDocx = Неопределено Или ДвоичныеДанныеDocx.Размер() = 0 Тогда
		Возврат;
	КонецЕсли;

	АдресДвоичныхДанных = ПоместитьВоВременноеХранилище(ДвоичныеДанныеDocx);

	СведенияФайла = РаботаСФайламиКлиентСервер.СведенияОФайле("ФайлСВерсией");
	СведенияФайла.ИмяБезРасширения = ИмяБезРасширения;
	СведенияФайла.Комментарий = НСтр("ru = 'Сформировано автоматически после анализа ИИ'");
	СведенияФайла.ХранитьВерсии = Истина;
	СведенияФайла.РасширениеБезТочки = "docx";
	СведенияФайла.АдресВременногоХранилищаФайла = АдресДвоичныхДанных;
	СведенияФайла.Размер = ДвоичныеДанныеDocx.Размер();
	СведенияФайла.ВремяИзменения = ТекущаяДатаСеанса();
	СведенияФайла.ВремяИзмененияУниверсальное = РаботаСФайламиКлиентСервер.ПолучитьУниверсальноеВремя(
		СведенияФайла.ВремяИзменения);
	СведенияФайла.НоваяВерсияКомментарий = НСтр("ru = 'Ответ модели (DOCX)'");
	СведенияФайла.ОригинальноеИмя = ИмяБезРасширения + ".docx";

	РаботаСФайламиВызовСервера.СоздатьФайлСВерсией(ДокументСсылка, СведенияФайла);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИАДО_СанитизироватьИмяФайлаДляВложения(Знач Имя)

	Результат = Имя;
	НаборСимволов = Новый Массив;
	НаборСимволов.Добавить("\");
	НаборСимволов.Добавить("/");
	НаборСимволов.Добавить(":");
	НаборСимволов.Добавить("*");
	НаборСимволов.Добавить("?");
	НаборСимволов.Добавить("""");
	НаборСимволов.Добавить("<");
	НаборСимволов.Добавить(">");
	НаборСимволов.Добавить("|");

	Для Каждого Сим Из НаборСимволов Цикл
		Результат = СтрЗаменить(Результат, Сим, "_");
	КонецЦикла;

	Возврат СокрЛП(Результат);

КонецФункции

Функция ИАДО_ЭкранироватьТекстДляWordOpenXml(Знач Текст)

	Результат = СтрЗаменить(Текст, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");
	Результат = СтрЗаменить(Результат, Символ(160), " ");

	Возврат Результат;

КонецФункции

Функция ИАДО_СобратьДвоичныеДанныеDocxПоТексту(Знач Текст)

	Результат = Неопределено;
	КаталогСборки = "";
	ПутьАрхива = "";
	Разделитель = ПолучитьРазделительПути();

	Попытка

		КаталогСборки = КаталогВременныхФайлов() + Разделитель + "iadodocx_"
			+ Строка(Новый УникальныйИдентификатор());
		СоздатьКаталог(КаталогСборки);
		СоздатьКаталог(КаталогСборки + Разделитель + "_rels");
		СоздатьКаталог(КаталогСборки + Разделитель + "word");
		СоздатьКаталог(КаталогСборки + Разделитель + "word" + Разделитель + "_rels");

		ИмяТипов = КаталогСборки + Разделитель + "[Content_Types].xml";
		ИАДО_ЗаписатьТекстВФайлUtf8(
			ИмяТипов,
			"<?xml version=""1.0"" encoding=""UTF-8"" standalone=""yes""?>"
				+ Символы.ПС
				+ "<Types xmlns=""http://schemas.openxmlformats.org/package/2006/content-types"">"
				+ "<Default Extension=""rels"" ContentType=""application/vnd.openxmlformats-package.relationships+xml""/>"
				+ "<Default Extension=""xml"" ContentType=""application/xml""/>"
				+ "<Override PartName=""/word/document.xml"""
				+ " ContentType=""application/vnd.openxmlformats-officedocument.wordprocessingml.document.main+xml""/>"
				+ "</Types>");

		ИАДО_ЗаписатьТекстВФайлUtf8(
			КаталогСборки + Разделитель + "_rels" + Разделитель + ".rels",
			"<?xml version=""1.0"" encoding=""UTF-8"" standalone=""yes""?>"
				+ Символы.ПС
				+ "<Relationships xmlns=""http://schemas.openxmlformats.org/package/2006/relationships"">"
				+ "<Relationship Id=""rId1"""
				+ " Type=""http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument"""
				+ " Target=""word/document.xml""/>"
				+ "</Relationships>");

		ИАДО_ЗаписатьТекстВФайлUtf8(
			КаталогСборки + Разделитель + "word" + Разделитель + "_rels" + Разделитель + "document.xml.rels",
			"<?xml version=""1.0"" encoding=""UTF-8"" standalone=""yes""?>"
				+ Символы.ПС
				+ "<Relationships xmlns=""http://schemas.openxmlformats.org/package/2006/relationships""/>");

		ТекстТела = ИАДО_ПостроитьWordDocumentXmlСОформлением(Текст);
		ИАДО_ЗаписатьТекстВФайлUtf8(
			КаталогСборки + Разделитель + "word" + Разделитель + "document.xml",
			ТекстТела);

		ПутьАрхива = ПолучитьИмяВременногоФайла("docx");
		ЗаписьАрхива = Новый ЗаписьZipФайла(ПутьАрхива, "", "");
		ЗаписьАрхива.Добавить(
			КаталогСборки + Разделитель + "*.*",
			РежимСохраненияПутейZIP.СохранятьОтносительныеПути,
			РежимОбработкиПодкаталоговZIP.ОбрабатыватьРекурсивно);
		ЗаписьАрхива.Записать();

		Результат = Новый ДвоичныеДанные(ПутьАрхива);

	Исключение

		Результат = Неопределено;

	КонецПопытки;

	Если Не ПустаяСтрока(КаталогСборки) Тогда
		ИАДО_УдалитьЛокальныеФайлыСборкиDocx(КаталогСборки, Разделитель);
	КонецЕсли;

	Если Не ПустаяСтрока(ПутьАрхива) Тогда
		ФайлАрхива = Новый Файл(ПутьАрхива);
		Если ФайлАрхива.Существует() Тогда
			Попытка
				УдалитьФайлы(ПутьАрхива);
			Исключение
				ИАДО_НетДействийПослеОшибкиУдаленияВременногоФайла();
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;

	Возврат Результат;

КонецФункции

Процедура ИАДО_ЗаписатьТекстВФайлUtf8(Знач ИмяФайла, Знач Текст)

	Запись = Новый ЗаписьТекста(ИмяФайла, КодировкаТекста.UTF8);
	Запись.Записать(Текст);
	Запись.Закрыть();

КонецПроцедуры

// Формирует word/document.xml: базовое оформление ответа ИИ (заголовки #, жирный **, курсив *, линия ---).
//
Функция ИАДО_ПостроитьWordDocumentXmlСОформлением(Знач Текст)

	МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Текст, Символы.ПС, Ложь);
	Если МассивСтрок.Количество() = 0 Тогда
		МассивСтрок.Добавить("");
	КонецЕсли;

	Части = Новый Массив;
	Части.Добавить("<?xml version=""1.0"" encoding=""UTF-8"" standalone=""yes""?>");
	Части.Добавить(
		"<w:document xmlns:w=""http://schemas.openxmlformats.org/wordprocessingml/2006/main"">");
	Части.Добавить("<w:body>");

	Для Каждого СтрокаИзМассива Из МассивСтрок Цикл
		Части.Добавить(ИАДО_WordOpenXmlПараграфПоСтрокеMarkdown(СтрокаИзМассива));
	КонецЦикла;

	Части.Добавить("</w:body>");
	Части.Добавить("</w:document>");

	Возврат СтрСоединить(Части, Символы.ПС);

КонецФункции

Функция ИАДО_WordOpenXmlПараграфПоСтрокеMarkdown(Знач ИсходнаяСтрока)

	ВедущиеСимволы = ИАДО_КоличествоВедущихПробеловИТабов(ИсходнаяСтрока);
	СтрокаАнализа = СокрЛП(ИсходнаяСтрока);

	Если ПустаяСтрока(СтрокаАнализа) Тогда
		Возврат "<w:p><w:pPr><w:spacing w:after=""80""/></w:pPr></w:p>";
	КонецЕсли;

	Если ИАДО_СтрокаЯвляетсяРазделителемMarkdown(СтрокаАнализа) Тогда
		Возврат "<w:p><w:pPr><w:pBdr><w:bottom w:val=""single"" w:sz=""12"" w:space=""1"" w:color=""BBBBBB""/>"
			+ "</w:pBdr><w:spacing w:before=""120"" w:after=""120""/></w:pPr></w:p>";
	КонецЕсли;

	ДопОтступ = Мин(ВедущиеСимволы, 40) * 180;

	УровеньЗаголовка = 0;
	ТекстСтроки = СтрокаАнализа;
	ЦветАбзаца = "";

	Если СтрНачинаетсяС(СтрокаАнализа, "### ") Тогда
		УровеньЗаголовка = 3;
		ТекстСтроки = Сред(СтрокаАнализа, 5);
		ЦветАбзаца = "2E5694";
	ИначеЕсли СтрНачинаетсяС(СтрокаАнализа, "## ") Тогда
		УровеньЗаголовка = 2;
		ТекстСтроки = Сред(СтрокаАнализа, 4);
		ЦветАбзаца = "2E5694";
	ИначеЕсли СтрНачинаетсяС(СтрокаАнализа, "# ") Тогда
		УровеньЗаголовка = 1;
		ТекстСтроки = Сред(СтрокаАнализа, 3);
		ЦветАбзаца = "1F3864";
	КонецЕсли;

	РазмерШрифта = 24;
	Если УровеньЗаголовка = 1 Тогда
		РазмерШрифта = 40;
	ИначеЕсли УровеньЗаголовка = 2 Тогда
		РазмерШрифта = 32;
	ИначеЕсли УровеньЗаголовка = 3 Тогда
		РазмерШрифта = 28;
	КонецЕсли;

	ПрефиксНумерации = "";
	Если УровеньЗаголовка = 0 Тогда
		РазборНомера = ИАДО_РазборПрефиксаНумерованногоСписка(СтрокаАнализа);
		Если РазборНомера.ЕстьНомер Тогда
			ПрефиксНумерации = РазборНомера.Префикс + " ";
			ТекстСтроки = РазборНомера.Текст;
			ДопОтступ = ДопОтступ + 360;
		ИначеЕсли ИАДО_ЭтоМаркированныйЭлементMarkdownПослеМаркера(СтрокаАнализа, "-") Тогда
			ТекстСтроки = ИАДО_ТекстМаркированногоЭлементаMarkdown(СтрокаАнализа, "-");
			ПрефиксНумерации = "• ";
			ДопОтступ = ДопОтступ + 360;
		ИначеЕсли ИАДО_ЭтоМаркированныйЭлементMarkdownПослеМаркера(СтрокаАнализа, "*") Тогда
			ТекстСтроки = ИАДО_ТекстМаркированногоЭлементаMarkdown(СтрокаАнализа, "*");
			ПрефиксНумерации = "• ";
			ДопОтступ = ДопОтступ + 360;
		КонецЕсли;
	КонецЕсли;

	ТекстДляПроверки = НРег(СокрЛП(ТекстСтроки));
	Если СтрНайти(ТекстДляПроверки, "красная зона") > 0 Тогда
		ЦветАбзаца = "C00000";
	КонецЕсли;

	Возврат ИАДО_WordOpenXmlАбзацСРазметкой(
		ТекстСтроки,
		РазмерШрифта,
		ДопОтступ,
		УровеньЗаголовка,
		ПрефиксНумерации,
		ЦветАбзаца);

КонецФункции

Функция ИАДО_WordOpenXmlАбзацСРазметкой(
	Знач ТекстСтроки,
	Знач РазмерШрифта,
	Знач ДопОтступTwips,
	Знач УровеньЗаголовка,
	Знач ПрефиксНумерации,
	Знач ЦветАбзаца)

	ИнтервалПосле = ?(УровеньЗаголовка > 0, 200, 140);

	Если УровеньЗаголовка = 1 Тогда
		ИнтервалДо = 240;
	ИначеЕсли УровеньЗаголовка > 0 Тогда
		ИнтервалДо = 180;
	Иначе
		ИнтервалДо = 0;
	КонецЕсли;

	ЧастиПараграфа = Новый Массив;
	ЧастиПараграфа.Добавить("<w:p><w:pPr>");
	ЧастиПараграфа.Добавить("<w:spacing w:before=""" + Формат(ИнтервалДо, "ЧГ=0") + """ w:after="""
		+ Формат(ИнтервалПосле, "ЧГ=0") + """ w:line=""276"" w:lineRule=""auto""/>");
	Если ДопОтступTwips > 0 Тогда
		ЧастиПараграфа.Добавить("<w:ind w:left=""" + Формат(ДопОтступTwips, "ЧГ=0") + """/>");
	КонецЕсли;
	ЧастиПараграфа.Добавить("<w:jc w:val=""both""/>");
	ЧастиПараграфа.Добавить("</w:pPr>");

	Если Не ПустаяСтрока(ПрефиксНумерации) Тогда
		ИАДО_WordOpenXmlДобавитьRunВМассив(
			ЧастиПараграфа,
			ПрефиксНумерации,
			Истина,
			Ложь,
			РазмерШрифта,
			ЦветАбзаца);
	КонецЕсли;

	ИАДО_WordOpenXmlДобавитьRunsРазметкиMarkdown(
		ЧастиПараграфа,
		ТекстСтроки,
		РазмерШрифта,
		ЦветАбзаца,
		УровеньЗаголовка > 0);

	ЧастиПараграфа.Добавить("</w:p>");

	Возврат СтрСоединить(ЧастиПараграфа, "");

КонецФункции

Процедура ИАДО_WordOpenXmlДобавитьRunsРазметкиMarkdown(
	ЧастиПараграфа,
	Знач Текст,
	Знач РазмерШрифта,
	Знач ЦветАбзаца,
	Знач ЖирныйКакУЗаголовка)

	Индекс = 1;
	Буфер = "";
	Жирный = Ложь;
	Курсив = Ложь;

	Пока Индекс <= СтрДлина(Текст) Цикл

		Если Индекс < СтрДлина(Текст) И Сред(Текст, Индекс, 2) = "**" Тогда
			ИАДО_WordOpenXmlДобавитьRunВМассив(
				ЧастиПараграфа,
				Буфер,
				Жирный Или ЖирныйКакУЗаголовка,
				Курсив,
				РазмерШрифта,
				ЦветАбзаца);
			Буфер = "";
			Жирный = Не Жирный;
			Индекс = Индекс + 2;
			Продолжить;
		КонецЕсли;

		Если Не Жирный И Сред(Текст, Индекс, 1) = "*" Тогда
			ИАДО_WordOpenXmlДобавитьRunВМассив(
				ЧастиПараграфа,
				Буфер,
				Жирный Или ЖирныйКакУЗаголовка,
				Курсив,
				РазмерШрифта,
				ЦветАбзаца);
			Буфер = "";
			Курсив = Не Курсив;
			Индекс = Индекс + 1;
			Продолжить;
		КонецЕсли;

		Буфер = Буфер + Сред(Текст, Индекс, 1);
		Индекс = Индекс + 1;

	КонецЦикла;

	ИАДО_WordOpenXmlДобавитьRunВМассив(
		ЧастиПараграфа,
		Буфер,
		Жирный Или ЖирныйКакУЗаголовка,
		Курсив,
		РазмерШрифта,
		ЦветАбзаца);

КонецПроцедуры

Процедура ИАДО_WordOpenXmlДобавитьRunВМассив(
	ЧастиПараграфа,
	Знач Текст,
	Знач Жирный,
	Знач Курсив,
	Знач РазмерШрифта,
	Знач Цвет)

	Если ПустаяСтрока(Текст) Тогда
		Возврат;
	КонецЕсли;

	ТекстXml = ИАДО_ЭкранироватьТекстДляWordOpenXml(Текст);

	Свойства = Новый Массив;
	Свойства.Добавить("<w:rPr>");

	Если Жирный Тогда
		Свойства.Добавить("<w:b/><w:bCs/>");
	КонецЕсли;

	Если Курсив Тогда
		Свойства.Добавить("<w:i/><w:iCs/>");
	КонецЕсли;

	Свойства.Добавить("<w:sz w:val=""" + Формат(РазмерШрифта, "ЧГ=0") + """/>");
	Свойства.Добавить("<w:szCs w:val=""" + Формат(РазмерШрифта, "ЧГ=0") + """/>");

	Если Не ПустаяСтрока(Цвет) Тогда
		Свойства.Добавить("<w:color w:val=""" + Цвет + """/>");
	КонецЕсли;

	Свойства.Добавить("</w:rPr>");

	ЧастиПараграфа.Добавить("<w:r>" + СтрСоединить(Свойства, "") + "<w:t xml:space=""preserve"">" + ТекстXml
		+ "</w:t></w:r>");

КонецПроцедуры

Функция ИАДО_КоличествоВедущихПробеловИТабов(Знач Строка)

	Результат = 0;
	Длина = СтрДлина(Строка);

	Для Индекс = 1 По Длина Цикл
		Символ = Сред(Строка, Индекс, 1);
		Если Символ = " " Или Символ = Символы.Таб Тогда
			Результат = Результат + 1;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ИАДО_ЭтоМаркированныйЭлементMarkdownПослеМаркера(Знач СтрокаАнализа, Знач Маркер)

	Если ПустаяСтрока(СтрокаАнализа) Или ПустаяСтрока(Маркер) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Лев(СтрокаАнализа, 1) <> Маркер Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Маркер = "-" И ИАДО_СтрокаЯвляетсяРазделителемMarkdown(СтрокаАнализа) Тогда
		Возврат Ложь;
	КонецЕсли;

	ПозицияМаркера = 2;
	ДлинаСтроки = СтрДлина(СтрокаАнализа);

	Пока ПозицияМаркера <= ДлинаСтроки Цикл
		СимволСтроки = Сред(СтрокаАнализа, ПозицияМаркера, 1);
		Если СимволСтроки = " " Или СимволСтроки = Символы.Таб Тогда
			ПозицияМаркера = ПозицияМаркера + 1;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат ПозицияМаркера <= ДлинаСтроки;

КонецФункции

Функция ИАДО_ТекстМаркированногоЭлементаMarkdown(Знач СтрокаАнализа, Знач Маркер)

	Если ПустаяСтрока(СтрокаАнализа) Или Лев(СтрокаАнализа, 1) <> Маркер Тогда
		Возврат СокрЛП(СтрокаАнализа);
	КонецЕсли;

	ПозицияМаркера = 2;
	ДлинаСтроки = СтрДлина(СтрокаАнализа);

	Пока ПозицияМаркера <= ДлинаСтроки Цикл
		СимволСтроки = Сред(СтрокаАнализа, ПозицияМаркера, 1);
		Если СимволСтроки = " " Или СимволСтроки = Символы.Таб Тогда
			ПозицияМаркера = ПозицияМаркера + 1;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат СокрЛП(Сред(СтрокаАнализа, ПозицияМаркера));

КонецФункции

Функция ИАДО_СтрокаЯвляетсяРазделителемMarkdown(Знач СтрокаПроверки)

	Если СтрДлина(СтрокаПроверки) < 3 Тогда
		Возврат Ложь;
	КонецЕсли;

	Первый = Лев(СтрокаПроверки, 1);
	Если Первый <> "-" И Первый <> "*" И Первый <> "_" Тогда
		Возврат Ложь;
	КонецЕсли;

	Для Индекс = 1 По СтрДлина(СтрокаПроверки) Цикл
		Если Сред(СтрокаПроверки, Индекс, 1) <> Первый Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат Истина;

КонецФункции

Функция ИАДО_РазборПрефиксаНумерованногоСписка(Знач СтрокаСписка)

	Результат = Новый Структура("ЕстьНомер, Префикс, Текст");
	Результат.ЕстьНомер = Ложь;
	Результат.Префикс = "";
	Результат.Текст = СтрокаСписка;

	Если ПустаяСтрока(СтрокаСписка) Тогда
		Возврат Результат;
	КонецЕсли;

	Позиция = 1;

	Пока Позиция <= СтрДлина(СтрокаСписка) Цикл
		Символ = Сред(СтрокаСписка, Позиция, 1);
		Если СтрНайти("0123456789", Символ) = 0 Тогда
			Прервать;
		КонецЕсли;
		Позиция = Позиция + 1;
	КонецЦикла;

	Если Позиция = 1 Тогда
		Возврат Результат;
	КонецЕсли;

	Если Позиция > СтрДлина(СтрокаСписка) Тогда
		Возврат Результат;
	КонецЕсли;

	Если Сред(СтрокаСписка, Позиция, 1) <> "." Тогда
		Возврат Результат;
	КонецЕсли;

	Если Позиция >= СтрДлина(СтрокаСписка) Тогда
		Возврат Результат;
	КонецЕсли;

	СимволПослеТочки = Сред(СтрокаСписка, Позиция + 1, 1);
	Если СимволПослеТочки <> " " И СимволПослеТочки <> Символы.Таб Тогда
		Возврат Результат;
	КонецЕсли;

	Хвост = Сред(СтрокаСписка, Позиция + 1);
	Если ПустаяСтрока(СокрЛП(Хвост)) Тогда
		Результат.ЕстьНомер = Истина;
		Результат.Префикс = Лев(СтрокаСписка, Позиция);
		Результат.Текст = "";
		Возврат Результат;
	КонецЕсли;

	Результат.ЕстьНомер = Истина;
	Результат.Префикс = Лев(СтрокаСписка, Позиция);
	Результат.Текст = СокрЛП(Хвост);

	Возврат Результат;

КонецФункции

Процедура ИАДО_УдалитьЛокальныеФайлыСборкиDocx(Знач КаталогСборки, Знач Разделитель)

	Кандидаты = Новый Массив;
	Кандидаты.Добавить(КаталогСборки + Разделитель + "[Content_Types].xml");
	Кандидаты.Добавить(КаталогСборки + Разделитель + "_rels" + Разделитель + ".rels");
	Кандидаты.Добавить(КаталогСборки + Разделитель + "word" + Разделитель + "document.xml");
	Кандидаты.Добавить(
		КаталогСборки + Разделитель + "word" + Разделитель + "_rels" + Разделитель + "document.xml.rels");

	Для Каждого ПутьКФайлу Из Кандидаты Цикл

		Попытка
			ФайлНаДиске = Новый Файл(ПутьКФайлу);
			Если ФайлНаДиске.Существует() Тогда
				УдалитьФайлы(ПутьКФайлу);
			КонецЕсли;
		Исключение
			ИАДО_НетДействийПослеОшибкиУдаленияВременногоФайла();
		КонецПопытки;

	КонецЦикла;

КонецПроцедуры

// Заглушка для ветки Исключение при очистке временных файлов DOCX.
Процедура ИАДО_НетДействийПослеОшибкиУдаленияВременногоФайла()
	Возврат;
КонецПроцедуры

