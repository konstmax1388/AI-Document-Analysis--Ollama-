
// Только сервер: для расширения недопустима комбинация «глобальный серверный»; лишние контексты
// в #Если могут приводить к ошибке загрузки «…глобальных серверных общих модулей в расширении».
#Если Сервер Тогда

#Область ПрограммныйИнтерфейс

// Запускает длительную операцию ИИ в фоне (БСП ДлительныеОперации).
//
// Параметры:
//  ПараметрыОперации - Структура - обязательно ИмяОперации; для «АнализФайла»: Документ, Файл.
//  ИдентификаторФормы - УникальныйИдентификатор - идентификатор формы-владельца.
//
// Возвращаемое значение:
//  см. ДлительныеОперации.ВыполнитьФункцию
//
Функция НачатьОперациюИИВФоне(Знач ПараметрыОперации, Знач ИдентификаторФормы = Неопределено) Экспорт

	Если ИдентификаторФормы = Неопределено Тогда
		ИдентификаторФормы = Новый УникальныйИдентификатор();
	КонецЕсли;

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'ИИ (Ollama): выполнение операции'");
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ОжидатьЗавершение = 0;

	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
		"ИАДО_ИнтеграцияИИВызовСервера.ВыполнитьОперациюИИВФоне",
		ПараметрыОперации);

КонецФункции

// Выполняет шаг схемы «запуск анализа файла» без Запрос.Выполнить в тексте скрипта схемы.
// Точка входа для скрипта — см. ИАДО_СценарийСхемыОбработкиОбъектаВызовСервера (прямой вызов при lvv)
// или ОбщегоНазначения.ВыполнитьМетодКонфигурации с полным именем этой процедуры (тоже при lvv).
// Без lvv и только ВыполнитьВБезопасномРежиме: ВыполнитьМетодКонфигурации из скрипта недопустим.
// Скрипты схем обработки объекта выполняются в безопасном режиме: встроенная проверка алгоритма
// запрещает конструкцию «.Выполнить(», из‑за чего нельзя вызывать Запрос.Выполнить() из скрипта.
//
// Параметры:
//  ДокументСсылка — СправочникСсылка.ДокументыПредприятия или СправочникОбъект.ДокументыПредприятия;
//   в схеме обработки у Параметры.ОбработкаОбъект.Владелец иногда приходит объект карточки.
//
Процедура ЗапуститьАнализФайлаИзСкриптаСхемыПоДокументу(Знач ДокументСсылка) Экспорт

	ДокументСсылка = ИАДО_НормализоватьСсылкуДокументаДляСценарияИИ(ДокументСсылка);

	Если Не ЗначениеЗаполнено(ДокументСсылка) Тогда
		Возврат;
	КонецЕсли;

	ФайлДляАнализа = ИАДО_ПодобратьФайлПроектаДоговораДляАнализаИИ(ДокументСсылка);
	Если Не ЗначениеЗаполнено(ФайлДляАнализа) Тогда
		Возврат;
	КонецЕсли;

	Если ИАДО_УжеЕстьУспешныйЖурналОтветаМодели(ДокументСсылка, ФайлДляАнализа) Тогда
		Возврат;
	КонецЕсли;

	Если ИАДО_ОчередьРаспознаванияИИВызовСервера.ОчередьРаспознаванияИАДОАктивна(ДокументСсылка, ФайлДляАнализа) Тогда
		Возврат;
	КонецЕсли;

	Если ИАДО_ИдетШтатноеРаспознаваниеТекущейВерсии(ФайлДляАнализа) Тогда
		Возврат;
	КонецЕсли;

	Если ИАДО_ВКарточкеДокументаЕстьФайлОтветаИИ(ДокументСсылка) Тогда
		Возврат;
	КонецЕсли;

	ПараметрыОперации = Новый Структура;
	ПараметрыОперации.Вставить("ИмяОперации", "АнализФайла");
	ПараметрыОперации.Вставить("Документ", ДокументСсылка);
	ПараметрыОперации.Вставить("Файл", ФайлДляАнализа);

	НачатьОперациюИИВФоне(ПараметрыОперации);

КонецПроцедуры

// Обработчик фонового задания; вызывается только подсистемой длительных операций.
//
// Параметры:
//  ПараметрыОперации - Структура - параметры, переданные из НачатьОперациюИИВФоне (ИмяОперации и др.).
//
// Возвращаемое значение:
//  Структура:
//   * Успех - Булево - признак успешного выполнения операции.
//   * Сообщение - Строка - текст ошибки/диагностики, пустая строка при успехе.
//   * ТекстМодели - Строка - добавляется только для операции «АнализФайла» при успехе.
//
Функция ВыполнитьОперациюИИВФоне(Знач ПараметрыОперации) Экспорт

	ИмяОперации = "";
	Если ТипЗнч(ПараметрыОперации) = Тип("Структура") И ПараметрыОперации.Свойство("ИмяОперации") Тогда
		ИмяОперации = ПараметрыОперации.ИмяОперации;
	КонецЕсли;

	Если ИмяОперации = "АнализФайла" Тогда
		Возврат ВыполнитьАнализФайлаВФоне(ПараметрыОперации);
	КонецЕсли;

	Возврат Новый Структура("Успех, Сообщение, ТекстМодели", Ложь, НСтр("ru = 'Неизвестная операция ИИ'"), "");

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выполняет анализ файла в фоне: подготовка текста, обращение к модели ИИ, журналирование.
//
// Параметры:
//  ПараметрыОперации - Структура - обязательные поля: Документ (СправочникСсылка.ДокументыПредприятия),
//   Файл (СправочникСсылка.Файлы).
//
// Возвращаемое значение:
//  Структура:
//   * Успех - Булево - признак успешного получения ответа модели.
//   * Сообщение - Строка - текст ошибки/диагностики, пустая строка при успехе.
//   * ТекстМодели - Строка - ответ модели; заполняется только при Успех = Истина.
//
Функция ВыполнитьАнализФайлаВФоне(Знач ПараметрыОперации)

	ДокументСсылка = ПараметрыОперации.Документ;
	ФайлСсылка = ПараметрыОперации.Файл;

	РеквДок = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументСсылка, "ВидДокумента, Тематика");
	ПараметрыАнализа = ИАДО_НастройкиАнализаИИВызовСервера.ПараметрыАнализаДокументаПоПравилам(
		РеквДок.ВидДокумента, РеквДок.Тематика);
	РасширениеФайла = ИАДО_РасширениеТекущейВерсииФайлаНРег(ФайлСсылка);
	ПередаватьPDFФайломВОблако = ПараметрыАнализа.ПровайдерИИ = Перечисления.ИАДО_ПровайдерыИИ.ОблакоOpenAIСовместимый
		И РасширениеФайла = "pdf"
		И Не ИАДО_НастройкиАнализаИИВызовСервера.ОблакоИИPDFТолькоТекст();

	ПодготовкаТекста = Новый Структура(
		"ТекстДляПромпта, ИсточникТекста, ДоступенДляМодели, СообщениеОбОшибке",
		"",
		"PDFИсходныйФайл",
		Истина,
		"");
	Если Не ПередаватьPDFФайломВОблако Тогда
		ПодготовкаТекста = ИАДО_ПодготовитьТекстДляАнализаСПриНеобходимостиРаспознавания(ФайлСсылка, ДокументСсылка);
	КонецЕсли;

	Если Не ПодготовкаТекста.ДоступенДляМодели И Не ПередаватьPDFФайломВОблако Тогда

		ПарамЖурнал = Новый Структура;
		ПарамЖурнал.Вставить("ВидОперации", "АнализФайла");
		ПарамЖурнал.Вставить("Успешно", Ложь);
		ПарамЖурнал.Вставить("Сообщение", ПодготовкаТекста.СообщениеОбОшибке);
		ПарамЖурнал.Вставить("Документ", ДокументСсылка);
		ПарамЖурнал.Вставить("Файл", ФайлСсылка);
		ИАДО_ЖурналИИВызовСервера.ДобавитьЗапись(ПарамЖурнал);

		Возврат Новый Структура("Успех, Сообщение, ТекстМодели", Ложь, ПодготовкаТекста.СообщениеОбОшибке, "");

	КонецЕсли;

	Если Не ЗначениеЗаполнено(ПараметрыАнализа.Эксперт) Или ПустаяСтрока(ПараметрыАнализа.ИмяМодели) Тогда

		ТекстОшибки = НСтр("ru = 'Не найден эксперт ИИ по правилам для данного документа.'");
		ПарамЖурнал = Новый Структура;
		ПарамЖурнал.Вставить("ВидОперации", "АнализФайла");
		ПарамЖурнал.Вставить("Успешно", Ложь);
		ПарамЖурнал.Вставить("Сообщение", ТекстОшибки);
		ПарамЖурнал.Вставить("Документ", ДокументСсылка);
		ПарамЖурнал.Вставить("Файл", ФайлСсылка);
		ПарамЖурнал.Вставить("ИсточникТекстаФайла", ПодготовкаТекста.ИсточникТекста);
		ИАДО_ЖурналИИВызовСервера.ДобавитьЗапись(ПарамЖурнал);

		Возврат Новый Структура("Успех, Сообщение, ТекстМодели", Ложь, ТекстОшибки, "");

	КонецЕсли;

	Если ПустаяСтрока(СокрЛП(ПараметрыАнализа.ПромптОбработкиДокумента)) Тогда

		ТекстОшибки = НСтр("ru = 'Для подобранного правила не задан промпт. Укажите текст в ресурсе «Промпт обработки документа» в строке регистра ИАДО_ПравилаЭкспертовДокументов для данного вида и тематики.'");
		ПарамЖурнал = Новый Структура;
		ПарамЖурнал.Вставить("ВидОперации", "АнализФайла");
		ПарамЖурнал.Вставить("Успешно", Ложь);
		ПарамЖурнал.Вставить("Сообщение", ТекстОшибки);
		ПарамЖурнал.Вставить("Документ", ДокументСсылка);
		ПарамЖурнал.Вставить("Файл", ФайлСсылка);
		ПарамЖурнал.Вставить("ИсточникТекстаФайла", ПодготовкаТекста.ИсточникТекста);
		ИАДО_ЖурналИИВызовСервера.ДобавитьЗапись(ПарамЖурнал);

		Возврат Новый Структура("Успех, Сообщение, ТекстМодели", Ложь, ТекстОшибки, "");

	КонецЕсли;

	МаксДлинаТекста = 200000;
	ТекстДок = "";
	Если Не ПередаватьPDFФайломВОблако Тогда
		ТекстДок = ПодготовкаТекста.ТекстДляПромпта;
		Если СтрДлина(ТекстДок) > МаксДлинаТекста Тогда
			ТекстДок = Лев(ТекстДок, МаксДлинаТекста) + Символы.ПС + НСтр("ru = '...[фрагмент текста обрезан для промпта]...'");
		КонецЕсли;
	КонецЕсли;

	ПромптПравила = СокрЛП(ПараметрыАнализа.ПромптОбработкиДокумента);
	Если ПередаватьPDFФайломВОблако Тогда
		ПользовательскийПромпт = ПромптПравила + Символы.ПС + Символы.ПС
			+ НСтр("ru = 'Проанализируй приложенный PDF-файл и сформируй ответ по указанным правилам.'");
	Иначе
		ПользовательскийПромпт = ПромптПравила;
		Если Не ПустаяСтрока(ПользовательскийПромпт) Тогда
			ПользовательскийПромпт = ПользовательскийПромпт + Символы.ПС + Символы.ПС;
		КонецЕсли;
		ПользовательскийПромпт = ПользовательскийПромпт + ТекстДок;
	КонецЕсли;

	ПарамСобытияЖурнала = Новый Структура;
	ПарамСобытияЖурнала.Вставить("ВидОперации", "ОбращениеКМоделиНачало");
	ПарамСобытияЖурнала.Вставить("Успешно", Истина);
	ПарамСобытияЖурнала.Вставить("Сообщение", НСтр("ru = 'Запуск обращения к модели ИИ'"));
	ПарамСобытияЖурнала.Вставить("Документ", ДокументСсылка);
	ПарамСобытияЖурнала.Вставить("Файл", ФайлСсылка);
	ПарамСобытияЖурнала.Вставить("ИмяМодели", ПараметрыАнализа.ИмяМодели);
	ПарамСобытияЖурнала.Вставить("ИсточникТекстаФайла", ПодготовкаТекста.ИсточникТекста);
	ПарамСобытияЖурнала.Вставить("Детали", Новый Структура(
		"ПровайдерИИ, ДлинаПромпта", ПараметрыАнализа.ПровайдерИИ, СтрДлина(ПользовательскийПромпт)));
	ИАДО_ЗаписатьСобытиеЖурналаИИ(ПарамСобытияЖурнала);

	Если ПараметрыАнализа.ПровайдерИИ = Перечисления.ИАДО_ПровайдерыИИ.ОблакоOpenAIСовместимый Тогда
		ДвоичныеДанныеPDF = Неопределено;
		ИмяФайлаPDF = "";
		Если ПередаватьPDFФайломВОблако Тогда
			ДвоичныеДанныеPDF = РаботаСФайламиВызовСервера.ПолучитьДвоичныеДанныеФайла(ФайлСсылка);
			Если ДвоичныеДанныеPDF = Неопределено Или ДвоичныеДанныеPDF.Размер() = 0 Тогда
				ТекстОшибки = НСтр("ru = 'Не удалось получить двоичные данные PDF для передачи в облачный ИИ.'");
				Возврат Новый Структура("Успех, Сообщение, ТекстМодели", Ложь, ТекстОшибки, "");
			КонецЕсли;
			ИмяФайлаPDF = ИАДО_ИмяФайлаДляПередачиВОблако(ФайлСсылка, РасширениеФайла);
		КонецЕсли;

		РезультатВызова = ИАДО_ИнтеграцияOpenAIСовместимыйВызовСервера.СгенерироватьОтветЧат(
			ИАДО_НастройкиАнализаИИВызовСервера.БазовыйURL_ОблакоИИ(),
			ИАДО_НастройкиАнализаИИВызовСервера.ТаймаутHTTPСекундОблакоИИ(),
			ИАДО_НастройкиАнализаИИВызовСервера.КлючAPI_ОблакоИИ(),
			ПараметрыАнализа.ИмяМодели,
			ПользовательскийПромпт,
			ПараметрыАнализа.СистемныйПромпт,
			ДвоичныеДанныеPDF,
			ИмяФайлаPDF);

	Иначе

		РезультатВызова = ИАДО_ИнтеграцияOllamaВызовСервера.СгенерироватьОтвет(
			ИАДО_НастройкиАнализаИИВызовСервера.БазовыйURL_Ollama(),
			ИАДО_НастройкиАнализаИИВызовСервера.ТаймаутHTTPСекунд(),
			ПараметрыАнализа.ИмяМодели,
			ПользовательскийПромпт,
			ПараметрыАнализа.СистемныйПромпт);

	КонецЕсли;

	ПарамЖурнал = Новый Структура;
	ПарамЖурнал.Вставить("ВидОперации", "АнализФайла");
	ПарамЖурнал.Вставить("Успешно", РезультатВызова.Успех);
	ПарамЖурнал.Вставить("Документ", ДокументСсылка);
	ПарамЖурнал.Вставить("Файл", ФайлСсылка);
	ПарамЖурнал.Вставить("ИмяМодели", ПараметрыАнализа.ИмяМодели);
	ПарамЖурнал.Вставить("ИсточникТекстаФайла", ПодготовкаТекста.ИсточникТекста);
	ПарамЖурнал.Вставить("HTTPКод", РезультатВызова.HTTPКод);

	Если РезультатВызова.Успех Тогда
		ПарамЖурнал.Вставить("Сообщение", НСтр("ru = 'Ответ модели получен'"));
		ПарамЖурнал.Вставить("ТекстОтветаКратко", Лев(РезультатВызова.ТекстМодели, 500));
	Иначе
		ТекстОшибки = РезультатВызова.СообщениеОбОшибке;
		Если ПустаяСтрока(ТекстОшибки) Тогда
			ТекстОшибки = РезультатВызова.ТекстОтвета;
		КонецЕсли;
		ПарамЖурнал.Вставить("Сообщение", ТекстОшибки);
	КонецЕсли;

	ИАДО_ЖурналИИВызовСервера.ДобавитьЗапись(ПарамЖурнал);

	Если РезультатВызова.Успех Тогда

		Попытка
			ИАДО_ОтветИИФайлДокументаВызовСервера.СоздатьФайлОтветаИИПоДокументу(
				ДокументСсылка,
				ФайлСсылка,
				РезультатВызова.ТекстМодели);
		Исключение
			ИАДО_ИгнорироватьОшибкуСозданияВложенияОтветаИИ();
		КонецПопытки;

		Возврат Новый Структура("Успех, Сообщение, ТекстМодели", Истина, "", РезультатВызова.ТекстМодели);

	КонецЕсли;

	ТекстОшибки = РезультатВызова.СообщениеОбОшибке;
	Если ПустаяСтрока(ТекстОшибки) Тогда
		ТекстОшибки = РезультатВызова.ТекстОтвета;
	КонецЕсли;

	Возврат Новый Структура("Успех, Сообщение, ТекстМодели", Ложь, ТекстОшибки, "");

КонецФункции

// Подготавливает текст файла для модели; при отсутствии текста и включенном распознавании ДО инициирует
// РаботаСФайламиВызовСервера.РаспознатьФайл и ожидает появления данных в регистре «Тексты версий файлов».
//
Функция ИАДО_ПодготовитьТекстДляАнализаСПриНеобходимостиРаспознавания(Знач ФайлСсылка, Знач ДокументСсылка)

	ПодготовкаТекста = ИАДО_ТекстФайлаДляИИВызовСервера.ПодготовитьТекстВерсииФайлаДляМодели(ФайлСсылка);
	Если ПодготовкаТекста.ДоступенДляМодели Тогда
		Возврат ПодготовкаТекста;
	КонецЕсли;

	ИдентификаторОчереди = ИАДО_ОчередьРаспознаванияИИВызовСервера.ПоставитьВОчередьРаспознавания(ФайлСсылка, ДокументСсылка);
	Если Не ИАДО_ОчередьРаспознаванияИИВызовСервера.ДождатьсяСвоейОчередиРаспознавания(
		ИдентификаторОчереди, ДокументСсылка, ФайлСсылка) Тогда

		ПодготовкаТекста.СообщениеОбОшибке = ПодготовкаТекста.СообщениеОбОшибке + Символы.ПС
			+ НСтр("ru = 'Истекло время ожидания своей очереди распознавания (5 мин).'");		
		ИАДО_ОчередьРаспознаванияИИВызовСервера.ЗавершитьОчередьРаспознавания(
			ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Ошибка", ПодготовкаТекста.СообщениеОбОшибке);
		Возврат ПодготовкаТекста;
	КонецЕсли;

	Если Не ИАДО_РаспознаваниеФайлаДоступноПередАнализомИИ(ФайлСсылка) Тогда
		ИАДО_ОчередьРаспознаванияИИВызовСервера.ЗавершитьОчередьРаспознавания(
			ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Завершено", "");
		Возврат ПодготовкаТекста;
	КонецЕсли;

	ИОМВладельца = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ТипЗнч(ДокументСсылка));
	ПараметрыРаспознавания = РаботаСФайламиВызовСервера.ПодготовитьПараметрыРаспознавания(ИОМВладельца);
	Если ПараметрыРаспознавания = Неопределено Тогда
		ИАДО_ОчередьРаспознаванияИИВызовСервера.ЗавершитьОчередьРаспознавания(
			ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Завершено", "");
		Возврат ПодготовкаТекста;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ПараметрыРаспознавания.СтратегияРаспознавания)
		Или ПараметрыРаспознавания.СтратегияРаспознавания = Перечисления.СтратегииРаспознаванияТекста.НеРаспознавать Тогда

		ПараметрыРаспознавания.СтратегияРаспознавания =
			Перечисления.СтратегииРаспознаванияТекста.ПоместитьТолькоВТекстовыйОбраз;

	КонецЕсли;

	ОписаниеОшибки = "";
	РаспознанныйТекст = "";
	РезультатРаспознавания = РаботаСФайламиВызовСервера.РаспознатьФайл(
		ФайлСсылка,
		ПараметрыРаспознавания,
		ОписаниеОшибки,
		РаспознанныйТекст,
		Неопределено,
		Истина);

	Если РезультатРаспознавания = "Ошибка" Тогда

		Если Не ПустаяСтрока(ОписаниеОшибки) Тогда
			ПодготовкаТекста.СообщениеОбОшибке = ПодготовкаТекста.СообщениеОбОшибке + Символы.ПС
				+ НСтр("ru = 'Запуск распознавания (Документооборот):'") + " " + ОписаниеОшибки;
		КонецЕсли;

		ИАДО_ОчередьРаспознаванияИИВызовСервера.ЗавершитьОчередьРаспознавания(
			ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Ошибка", ОписаниеОшибки);
		Возврат ПодготовкаТекста;

	КонецЕсли;

	МаксимальноеОжиданиеМс = ИАДО_ОчередьРаспознаванияИИВызовСервера.ЛимитОжиданияРаспознаванияМиллисекунд();
	ИнтервалОпросаСек = 2;
	ВремяНачалаОжидания = ТекущаяУниверсальнаяДатаВМиллисекундах();

	Пока Истина Цикл

		ПодготовкаТекста = ИАДО_ТекстФайлаДляИИВызовСервера.ПодготовитьТекстВерсииФайлаДляМодели(ФайлСсылка);
		Если ПодготовкаТекста.ДоступенДляМодели Тогда
			ИАДО_ОчередьРаспознаванияИИВызовСервера.ЗавершитьОчередьРаспознавания(
				ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Завершено", "");
			Возврат ПодготовкаТекста;
		КонецЕсли;

		РеквизитыФайла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ФайлСсылка, "ТекущаяВерсия");
		ВерсияФайла = РеквизитыФайла.ТекущаяВерсия;
		СтатусРаспознавания = Неопределено;

		Если ЗначениеЗаполнено(ВерсияФайла) Тогда
			СтатусРаспознавания = РегистрыСведений.ТекстыВерсийФайлов.ПрочитатьСтатусРаспознавания(ВерсияФайла);
		КонецЕсли;

		Если СтатусРаспознавания = Перечисления.СтатусыРаспознаванияТекста.НеРаспознано Тогда
			ПодготовкаТекста.СообщениеОбОшибке = ПодготовкаТекста.СообщениеОбОшибке + Символы.ПС
				+ НСтр("ru = 'Распознавание завершилось со статусом «Не распознано»; текст для модели недоступен.'");
			ИАДО_ОчередьРаспознаванияИИВызовСервера.ЗавершитьОчередьРаспознавания(
				ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Ошибка", ПодготовкаТекста.СообщениеОбОшибке);
			Возврат ПодготовкаТекста;
		КонецЕсли;

		Если ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачалаОжидания > МаксимальноеОжиданиеМс Тогда

			ПодготовкаТекста = ИАДО_ТекстФайлаДляИИВызовСервера.ПодготовитьТекстВерсииФайлаДляМодели(ФайлСсылка);
			Если Не ПодготовкаТекста.ДоступенДляМодели Тогда
				ПодготовкаТекста.СообщениеОбОшибке = ПодготовкаТекста.СообщениеОбОшибке + Символы.ПС
					+ НСтр("ru = 'Истекло время ожидания распознавания (5 мин). Повторите анализ позже или дождитесь окончания распознавания в карточке файла.'");
			КонецЕсли;

			ИАДО_ОчередьРаспознаванияИИВызовСервера.ЗавершитьОчередьРаспознавания(
				ИдентификаторОчереди, ДокументСсылка, ФайлСсылка, "Ошибка", ПодготовкаТекста.СообщениеОбОшибке);
			Возврат ПодготовкаТекста;

		КонецЕсли;

		ОбщегоНазначенияБТС.Пауза(ИнтервалОпросаСек);

	КонецЦикла;

КонецФункции

Процедура ИАДО_ЗаписатьСобытиеЖурналаИИ(Знач ПараметрыСобытия)

	ПарамЖурнал = Новый Структура;
	ПарамЖурнал.Вставить("ВидОперации", ПараметрыСобытия.ВидОперации);
	ПарамЖурнал.Вставить("Успешно", ПараметрыСобытия.Успешно);
	ПарамЖурнал.Вставить("Сообщение", ПараметрыСобытия.Сообщение);
	Если ПараметрыСобытия.Свойство("Документ") Тогда
		ПарамЖурнал.Вставить("Документ", ПараметрыСобытия.Документ);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("Файл") Тогда
		ПарамЖурнал.Вставить("Файл", ПараметрыСобытия.Файл);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("ИмяМодели") Тогда
		ПарамЖурнал.Вставить("ИмяМодели", ПараметрыСобытия.ИмяМодели);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("ИсточникТекстаФайла") Тогда
		ПарамЖурнал.Вставить("ИсточникТекстаФайла", ПараметрыСобытия.ИсточникТекстаФайла);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("HTTPКод") Тогда
		ПарамЖурнал.Вставить("HTTPКод", ПараметрыСобытия.HTTPКод);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("ТекстОтветаКратко") Тогда
		ПарамЖурнал.Вставить("ТекстОтветаКратко", ПараметрыСобытия.ТекстОтветаКратко);
	КонецЕсли;
	Если ПараметрыСобытия.Свойство("Детали") Тогда
		ПарамЖурнал.Вставить("Детали", ПараметрыСобытия.Детали);
	КонецЕсли;

	ИАДО_ЖурналИИВызовСервера.ДобавитьЗапись(ПарамЖурнал);

КонецПроцедуры

Функция ИАДО_РаспознаваниеФайлаДоступноПередАнализомИИ(Знач ФайлСсылка)

	Если Не РаботаСФайламиВызовСервера.ПолучитьИспользоватьРаспознаваниеТекста() Тогда
		Возврат Ложь;
	КонецЕсли;

	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ФайлСсылка, "Зашифрован, ТекущаяВерсияРасширение");
	Если Реквизиты.Зашифрован Тогда
		Возврат Ложь;
	КонецЕсли;

	ИспользоватьImageMagick = РаботаСФайламиВызовСервера.ПолучитьИспользоватьImageMagickДляРаспознаванияPDF();
	Если Не РаботаСФайламиВызовСервера.ИспользоватьGhostscript() Тогда
		ИспользоватьImageMagick = Ложь;
	КонецЕсли;

	ПараметрыПроверки = РаботаСФайламиКлиентСервер.ОписаниеПараметровПроверкиВозможностиРаспознавания();
	ПараметрыПроверки.ИспользоватьImageMagick = ИспользоватьImageMagick;
	ПараметрыПроверки.ПрограммаРаспознавания = РаботаСФайламиВызовСервера.ПрограммаРаспознавания();

	Расширение = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(Строка(Реквизиты.ТекущаяВерсияРасширение));

	Возврат РаботаСФайламиКлиентСервер.ЭтотФайлМожноРаспознать(Расширение, ПараметрыПроверки);

КонецФункции

Функция ИАДО_НормализоватьСсылкуДокументаДляСценарияИИ(Знач ДокументПроизвольно)

	Если Не ЗначениеЗаполнено(ДокументПроизвольно) Тогда
		Возврат Справочники.ДокументыПредприятия.ПустаяСсылка();
	КонецЕсли;

	ТипДок = ТипЗнч(ДокументПроизвольно);

	Если ТипДок = Тип("СправочникСсылка.ДокументыПредприятия") Тогда
		Возврат ДокументПроизвольно;
	ИначеЕсли ТипДок = Тип("СправочникОбъект.ДокументыПредприятия") Тогда
		Возврат ДокументПроизвольно.Ссылка;
	КонецЕсли;

	Возврат Справочники.ДокументыПредприятия.ПустаяСсылка();

КонецФункции

// Расширение текущей версии элемента Справочник.Файлы без точки, в нижнем регистре.
//
// Параметры:
//  ФайлСсылка - СправочникСсылка.Файлы
//
// Возвращаемое значение:
//  Строка
//
Функция ИАДО_РасширениеТекущейВерсииФайлаНРег(Знач ФайлСсылка)

	ТекущаяВерсияРасширение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФайлСсылка, "ТекущаяВерсияРасширение");
	Возврат НРег(СокрЛП(ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(Строка(ТекущаяВерсияРасширение))));

КонецФункции

Функция ИАДО_ИмяФайлаДляПередачиВОблако(Знач ФайлСсылка, Знач РасширениеФайла)

	ИмяФайла = СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФайлСсылка, "Наименование"));
	Если ПустаяСтрока(ИмяФайла) Тогда
		ИмяФайла = "document";
	КонецЕсли;

	Если ПустаяСтрока(РасширениеФайла) Тогда
		РасширениеФайла = "pdf";
	КонецЕсли;

	Если Прав(НРег(ИмяФайла), СтрДлина("." + НРег(РасширениеФайла))) <> "." + НРег(РасширениеФайла) Тогда
		ИмяФайла = ИмяФайла + "." + РасширениеФайла;
	КонецЕсли;

	Возврат ИмяФайла;

КонецФункции

Функция ИАДО_ИмяФайлаСодержитПодстрокуОтветИИ(Знач ФайлСсылка)

	Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФайлСсылка, "Наименование");

	Возврат СтрНайти(НРег(Строка(Наименование)), НРег("ответ ИИ")) > 0;

КонецФункции

Функция ИАДО_РольФайлаПроектДоговора(Знач ФайлСсылка)

	РольФайла = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФайлСсылка, "Роль");

	Если Не ЗначениеЗаполнено(РольФайла) Тогда
		Возврат Ложь;
	КонецЕсли;

	НаименованиеРоли = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РольФайла, "Наименование");

	Возврат СокрЛП(Строка(НаименованиеРоли)) = "Проект договора";

КонецФункции

Функция ИАДО_ФайлПодходитПоРасширениюДляАнализаИИ(Знач ФайлСсылка)

	РасширениеФайла = ИАДО_РасширениеТекущейВерсииФайлаНРег(ФайлСсылка);

	Возврат РасширениеФайла = "txt"
		Или РасширениеФайла = "doc"
		Или РасширениеФайла = "docx"
		Или РасширениеФайла = "rtf"
		Или РасширениеФайла = "pdf";

КонецФункции

Функция ИАДО_ПодобратьФайлПроектаДоговораДляАнализаИИ(Знач ДокументСсылка)

	Результат = Справочники.Файлы.ПустаяСсылка();
	ВсеФайлыДокумента = РаботаСФайламиВызовСервера.ПолучитьВсеПодчиненныеФайлы(ДокументСсылка, Ложь);

	Для Каждого ЭлементФайла Из ВсеФайлыДокумента Цикл

		Если ИАДО_ИмяФайлаСодержитПодстрокуОтветИИ(ЭлементФайла.Ссылка) Тогда
			Продолжить;
		КонецЕсли;

		Если Не ИАДО_ФайлПодходитПоРасширениюДляАнализаИИ(ЭлементФайла.Ссылка) Тогда
			Продолжить;
		КонецЕсли;

		Если ИАДО_РольФайлаПроектДоговора(ЭлементФайла.Ссылка) Тогда
			Возврат ЭлементФайла.Ссылка;
		КонецЕсли;

	КонецЦикла;

	Для Каждого ЭлементФайла Из ВсеФайлыДокумента Цикл

		Если ИАДО_ИмяФайлаСодержитПодстрокуОтветИИ(ЭлементФайла.Ссылка) Тогда
			Продолжить;
		КонецЕсли;

		Если ИАДО_ФайлПодходитПоРасширениюДляАнализаИИ(ЭлементФайла.Ссылка) Тогда
			Возврат ЭлементФайла.Ссылка;
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ИАДО_УжеЕстьУспешныйЖурналОтветаМодели(Знач ДокументСсылка, Знач ФайлСсылка)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	1 КАК ПолеЕсть
	|ИЗ
	|	РегистрСведений.ИАДО_ЖурналОбращенийКИИ КАК Журнал
	|ГДЕ
	|	Журнал.Документ = &Документ
	|	И Журнал.Файл = &Файл
	|	И Журнал.ВидОперации = ""АнализФайла""
	|	И Журнал.Успешно
	|	И Журнал.Сообщение ПОДОБНО &ШаблонУспеха
	|УПОРЯДОЧИТЬ ПО
	|	Журнал.ДатаВремя УБЫВ";

	Запрос.УстановитьПараметр("Документ", ДокументСсылка);
	Запрос.УстановитьПараметр("Файл", ФайлСсылка);
	Запрос.УстановитьПараметр("ШаблонУспеха", "%Ответ модели получен%");

	РезультатЗапроса = Запрос.Выполнить();
	Возврат Не РезультатЗапроса.Пустой();

КонецФункции

Функция ИАДО_ИдетШтатноеРаспознаваниеТекущейВерсии(Знач ФайлСсылка)

	ТекущаяВерсия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФайлСсылка, "ТекущаяВерсия");
	Если Не ЗначениеЗаполнено(ТекущаяВерсия) Тогда
		Возврат Ложь;
	КонецЕсли;

	СтатусРаспознавания = РегистрыСведений.ТекстыВерсийФайлов.ПрочитатьСтатусРаспознавания(ТекущаяВерсия);

	Возврат СтатусРаспознавания = Перечисления.СтатусыРаспознаванияТекста.Распознается;

КонецФункции

Функция ИАДО_ВКарточкеДокументаЕстьФайлОтветаИИ(Знач ДокументСсылка)

	ВсеФайлыДокумента = РаботаСФайламиВызовСервера.ПолучитьВсеПодчиненныеФайлы(ДокументСсылка, Ложь);

	Для Каждого ЭлементФайла Из ВсеФайлыДокумента Цикл

		Если ИАДО_ИмяФайлаСодержитПодстрокуОтветИИ(ЭлементФайла.Ссылка) Тогда
			Возврат Истина;
		КонецЕсли;

	КонецЦикла;

	Возврат Ложь;

КонецФункции

// Заглушка для ветки Исключение: вложение с ответом ИИ не обязательно для успешного анализа.
Процедура ИАДО_ИгнорироватьОшибкуСозданияВложенияОтветаИИ()
	Возврат;
КонецПроцедуры

