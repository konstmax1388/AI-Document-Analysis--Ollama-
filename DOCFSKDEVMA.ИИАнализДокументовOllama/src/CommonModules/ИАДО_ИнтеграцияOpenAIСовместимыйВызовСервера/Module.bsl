
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Выполняет запрос chat completions (POST …/chat/completions, stream = false).
//
// Параметры:
//  БазовыйURL - Строка - например https://api.deepseek.com/v1 без завершающего слэша.
//  ТаймаутСек - Число - таймаут HTTP в секундах.
//  КлючAPI - Строка - Bearer-токен (без префикса «Bearer »).
//  ИмяМодели - Строка - идентификатор модели у провайдера, например deepseek-chat.
//  ТекстПользователя - Строка - содержимое сообщения role=user.
//  СистемныйПромпт - Строка - необязательно; если задан, добавляется сообщение role=system.
//  ДвоичныеДанныеФайла - ДвоичныеДанные, Неопределено - бинарный файл для мультимодального запроса (например PDF).
//  ИмяФайла - Строка - имя файла для мультимодального запроса (например "Договор.pdf").
//
// Возвращаемое значение:
//  Структура:
//   * Успех - Булево
//   * HTTPКод - Число
//   * ТекстОтвета - Строка - укороченное JSON-тело ответа
//   * ТекстМодели - Строка - текст ответа ассистента
//   * СообщениеОбОшибке - Строка
//
Функция СгенерироватьОтветЧат(Знач БазовыйURL, Знач ТаймаутСек, Знач КлючAPI, Знач ИмяМодели,
	Знач ТекстПользователя, Знач СистемныйПромпт = "", Знач ДвоичныеДанныеФайла = Неопределено,
	Знач ИмяФайла = "") Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("HTTPКод", 0);
	Результат.Вставить("ТекстОтвета", "");
	Результат.Вставить("ТекстМодели", "");
	Результат.Вставить("СообщениеОбОшибке", "");

	ИмяМодели = СокрЛП(Строка(ИмяМодели));
	Если ПустаяСтрока(ИмяМодели) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не указано имя модели'");
		Возврат Результат;
	КонецЕсли;

	КлючAPI = СокрЛП(Строка(КлючAPI));
	Если ПустаяСтрока(КлючAPI) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не задан ключ API (константа «Облако ИИ: ключ API»)'");
		Возврат Результат;
	КонецЕсли;

	ТекстПользователя = Строка(ТекстПользователя);

	Контекст = КонтекстHTTPСоединенияПоБазовомуURL(БазовыйURL, ТаймаутСек);
	Если Не Контекст.Успех Тогда
		Результат.СообщениеОбОшибке = Контекст.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;

	ПутьЗапроса = Контекст.ПрефиксПути + "/chat/completions";

	Сообщения = Новый Массив;
	СистемныйПромпт = СокрЛП(Строка(СистемныйПромпт));
	Если Не ПустаяСтрока(СистемныйПромпт) Тогда
		СообщениеСистемы = Новый Структура;
		СообщениеСистемы.Вставить("role", "system");
		СообщениеСистемы.Вставить("content", СистемныйПромпт);
		Сообщения.Добавить(СообщениеСистемы);
	КонецЕсли;

	СообщениеПользователя = Новый Структура;
	СообщениеПользователя.Вставить("role", "user");
	СообщениеПользователя.Вставить(
		"content",
		СформироватьСодержимоеСообщенияПользователя(ТекстПользователя, ДвоичныеДанныеФайла, ИмяФайла));
	Сообщения.Добавить(СообщениеПользователя);

	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("model", ИмяМодели);
	ТелоЗапроса.Вставить("messages", Сообщения);
	ТелоЗапроса.Вставить("stream", Ложь);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ТелоЗапроса);
	СтрокаJSON = ЗаписьJSON.Закрыть();

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Заголовки.Вставить("Authorization", "Bearer " + КлючAPI);

	Попытка
		HTTPЗапрос = Новый HTTPЗапрос(ПутьЗапроса, Заголовки);
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);

		Ответ = Контекст.Соединение.ОтправитьДляОбработки(HTTPЗапрос);

		Результат.HTTPКод = Ответ.КодСостояния;
		Тело = Ответ.ПолучитьТелоКакСтроку("UTF-8");
		Результат.ТекстОтвета = СократитьСтрокуДляЖурнала(Тело, 2000);

		Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
			Результат.СообщениеОбОшибке = ТекстОшибкиИзТелаOpenAI(Тело, Ответ.КодСостояния);
			Возврат Результат;
		КонецЕсли;

		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Тело);
		ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON, Истина);

		Если ТипЗнч(ДанныеОтвета) <> Тип("Соответствие") Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'Не удалось разобрать ответ API как JSON-объект'");
			Возврат Результат;
		КонецЕсли;

		ТекстОшибкиAPI = ИзвлечьСообщениеОбОшибкеOpenAI(ДанныеОтвета);
		Если Не ПустаяСтрока(ТекстОшибкиAPI) Тогда
			Результат.СообщениеОбОшибке = ТекстОшибкиAPI;
			Возврат Результат;
		КонецЕсли;

		ТекстОтветаМодели = ИзвлечьТекстАссистентаИзОтветаЧат(ДанныеОтвета);
		Если ПустаяСтрока(ТекстОтветаМодели) Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'В ответе API отсутствует текст сообщения ассистента'");
			Возврат Результат;
		КонецЕсли;

		Результат.ТекстМодели = ТекстОтветаМодели;
		Результат.Успех = Истина;

	Исключение
		Результат.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция КонтекстHTTPСоединенияПоБазовомуURL(Знач БазовыйURL, Знач ТаймаутСек)

	Контекст = Новый Структура;
	Контекст.Вставить("Успех", Ложь);
	Контекст.Вставить("Соединение", Неопределено);
	Контекст.Вставить("ПрефиксПути", "");
	Контекст.Вставить("СообщениеОбОшибке", "");

	БазовыйURL = СокрЛП(Строка(БазовыйURL));
	Если ПустаяСтрока(БазовыйURL) Тогда
		Контекст.СообщениеОбОшибке = НСтр("ru = 'Не задан базовый URL API'");
		Возврат Контекст;
	КонецЕсли;

	Если СтрНайти(НРег(БазовыйURL), "://") = 0 Тогда
		БазовыйURL = "https://" + БазовыйURL;
	КонецЕсли;

	Если ТаймаутСек <= 0 Тогда
		ТаймаутСек = 30;
	КонецЕсли;

	Попытка
		СвойстваПодключения = ОбщегоНазначенияКлиентСервер.СтруктураURI(БазовыйURL);
	Исключение
		Контекст.СообщениеОбОшибке = НСтр("ru = 'Некорректный базовый URL'");
		Возврат Контекст;
	КонецПопытки;

	Если ПустаяСтрока(СвойстваПодключения.Хост) Тогда
		Контекст.СообщениеОбОшибке = НСтр("ru = 'В URL не указан хост'");
		Возврат Контекст;
	КонецЕсли;

	Порт = СвойстваПодключения.Порт;
	Если Порт = Неопределено Тогда
		Если НРег(СвойстваПодключения.Схема) = "https" Тогда
			Порт = 443;
		Иначе
			Порт = 80;
		КонецЕсли;
	КонецЕсли;

	ЗащищенноеСоединение = Неопределено;
	Если НРег(СвойстваПодключения.Схема) = "https" Тогда
		ЗащищенноеСоединение = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
	КонецЕсли;

	ПрефиксПути = "";
	Если Не ПустаяСтрока(СвойстваПодключения.ПутьНаСервере) Тогда
		ПрефиксПути = "/" + СокрЛП(СтрЗаменить(СвойстваПодключения.ПутьНаСервере, "\", "/"));
		Если Прав(ПрефиксПути, 1) = "/" Тогда
			ПрефиксПути = Лев(ПрефиксПути, СтрДлина(ПрефиксПути) - 1);
		КонецЕсли;
	КонецЕсли;

	Попытка
		Соединение = Новый HTTPСоединение(
			СвойстваПодключения.Хост,
			Порт,
			СвойстваПодключения.Логин,
			СвойстваПодключения.Пароль,
			,
			ТаймаутСек,
			ЗащищенноеСоединение);

		Контекст.Соединение = Соединение;
		Контекст.ПрефиксПути = ПрефиксПути;
		Контекст.Успех = Истина;
	Исключение
		Контекст.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Контекст;

КонецФункции

Функция СократитьСтрокуДляЖурнала(Знач Текст, Знач МаксДлина)

	Если СтрДлина(Текст) <= МаксДлина Тогда
		Возврат Текст;
	КонецЕсли;

	Возврат Лев(Текст, МаксДлина) + "...";

КонецФункции

Функция СформироватьСодержимоеСообщенияПользователя(
	Знач ТекстПользователя,
	Знач ДвоичныеДанныеФайла,
	Знач ИмяФайла)

	Если ДвоичныеДанныеФайла = Неопределено Тогда
		Возврат ТекстПользователя;
	КонецЕсли;

	Если ТипЗнч(ДвоичныеДанныеФайла) <> Тип("ДвоичныеДанные") Тогда
		Возврат ТекстПользователя;
	КонецЕсли;

	ИмяФайла = СокрЛП(Строка(ИмяФайла));
	Если ПустаяСтрока(ИмяФайла) Тогда
		ИмяФайла = "document.pdf";
	КонецЕсли;

	Контент = Новый Массив;

	БлокТекста = Новый Соответствие;
	БлокТекста.Вставить("type", "text");
	БлокТекста.Вставить("text", ТекстПользователя);
	Контент.Добавить(БлокТекста);

	БлокФайла = Новый Соответствие;
	БлокФайла.Вставить("type", "file");

	ОписаниеФайла = Новый Соответствие;
	ОписаниеФайла.Вставить("filename", ИмяФайла);
	ОписаниеФайла.Вставить("file_data", "data:application/pdf;base64," + Base64Строка(ДвоичныеДанныеФайла));
	БлокФайла.Вставить("file", ОписаниеФайла);

	Контент.Добавить(БлокФайла);

	Возврат Контент;

КонецФункции

Функция ТекстОшибкиИзТелаOpenAI(Знач Тело, Знач КодHTTP)

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Тело);
	Попытка
		Данные = ПрочитатьJSON(ЧтениеJSON, Истина);
	Исключение
		Возврат СтрШаблон(НСтр("ru = 'Сервер вернул код HTTP %1'"), Формат(КодHTTP, "ЧГ="));
	КонецПопытки;

	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		ТекстОшибки = ИзвлечьСообщениеОбОшибкеOpenAI(Данные);
		Если Не ПустаяСтрока(ТекстОшибки) Тогда
			Возврат ТекстОшибки;
		КонецЕсли;
	КонецЕсли;

	Возврат СтрШаблон(НСтр("ru = 'Сервер вернул код HTTP %1'"), Формат(КодHTTP, "ЧГ="));

КонецФункции

Функция ИзвлечьСообщениеОбОшибкеOpenAI(Знач ДанныеОтвета)

	Ошибка = ДанныеОтвета.Получить("error");
	Если Ошибка = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Если ТипЗнч(Ошибка) = Тип("Соответствие") Тогда
		Сообщение = Ошибка.Получить("message");
		Если Сообщение <> Неопределено Тогда
			Возврат Строка(Сообщение);
		КонецЕсли;
	КонецЕсли;

	Возврат Строка(Ошибка);

КонецФункции

Функция ИзвлечьТекстАссистентаИзОтветаЧат(Знач ДанныеОтвета)

	Варианты = ДанныеОтвета.Получить("choices");
	Если Варианты = Неопределено Или ТипЗнч(Варианты) <> Тип("Массив") Или Варианты.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;

	ЗаписьВыбора = Варианты[0];
	Если ТипЗнч(ЗаписьВыбора) <> Тип("Соответствие") Тогда
		Возврат "";
	КонецЕсли;

	Сообщение = ЗаписьВыбора.Получить("message");
	Если Сообщение = Неопределено Или ТипЗнч(Сообщение) <> Тип("Соответствие") Тогда
		Возврат "";
	КонецЕсли;

	Содержимое = Сообщение.Получить("content");
	Если Содержимое <> Неопределено И Не ПустаяСтрока(Строка(Содержимое)) Тогда
		Возврат Строка(Содержимое);
	КонецЕсли;

	Рассуждение = Сообщение.Получить("reasoning_content");
	Если Рассуждение <> Неопределено И Не ПустаяСтрока(Строка(Рассуждение)) Тогда
		Возврат Строка(Рассуждение);
	КонецЕсли;

	Возврат "";

КонецФункции

#КонецОбласти

