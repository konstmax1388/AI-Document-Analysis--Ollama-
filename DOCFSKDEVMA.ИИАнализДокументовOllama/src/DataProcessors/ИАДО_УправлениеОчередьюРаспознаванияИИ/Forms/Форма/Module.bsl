
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// У обработки отключены стандартные команды (метаданные): иначе форма без объекта записи
	// часто получает режим «только просмотр», и пользовательские команды недоступны.

	ОбновитьСводкуНаСервере();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьСводку(Команда)

	ОбновитьСводкуНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСписокРегистра(Команда)

	ОткрытьФорму("РегистрСведений.ИАДО_ОчередьРаспознаванияФайлов.ФормаСписка");

КонецПроцедуры

&НаКлиенте
Процедура СброситьЗависшие(Команда)

	Оповещение = Новый ОписаниеОповещения("ПослеВопросаСбросаЗависших", ЭтотОбъект);
	ТекстВопроса = НСтр("ru = 'Сбросить заявки в статусах «Ожидает» и «Выполняется», у которых последняя запись старше 15 минут?'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);

КонецПроцедуры

&НаКлиенте
Процедура ПослеВопросаСбросаЗависших(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	Количество = СброситьЗависшиеНаСервере();
	Текст = СтрШаблон(НСтр("ru = 'Сброшено заявок: %1'"), Формат(Количество, "ЧН=0; ЧГ="));
	ОбщегоНазначенияКлиент.СообщитьПользователю(Текст);
	ОбновитьСводкуНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура СброситьВсеАктивные(Команда)

	Оповещение = Новый ОписаниеОповещения("ПослеВопросаСбросаВсехАктивных", ЭтотОбъект);
	ТекстВопроса = НСтр("ru = 'Сбросить ВСЕ активные заявки (статусы «Ожидает» и «Выполняется»)?'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);

КонецПроцедуры

&НаКлиенте
Процедура ПослеВопросаСбросаВсехАктивных(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	Количество = СброситьВсеАктивныеНаСервере();
	Текст = СтрШаблон(НСтр("ru = 'Сброшено заявок: %1'"), Формат(Количество, "ЧН=0; ЧГ="));
	ОбщегоНазначенияКлиент.СообщитьПользователю(Текст);
	ОбновитьСводкуНаСервере();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьСводкуНаСервере()

	Сводка = ИАДО_ОчередьРаспознаванияИИВызовСервера.СводкаПоОчередиРаспознавания();
	ТекстСводки = Сводка.ТекстСводки;

КонецПроцедуры

&НаСервере
Функция СброситьЗависшиеНаСервере()

	Возврат ИАДО_ОчередьРаспознаванияИИВызовСервера.СброситьЗависшиеЗаявкиОчередиРаспознавания();

КонецФункции

&НаСервере
Функция СброситьВсеАктивныеНаСервере()

	Возврат ИАДО_ОчередьРаспознаванияИИВызовСервера.СброситьВсеАктивныеЗаявкиОчередиРаспознавания();

КонецФункции

#КонецОбласти
