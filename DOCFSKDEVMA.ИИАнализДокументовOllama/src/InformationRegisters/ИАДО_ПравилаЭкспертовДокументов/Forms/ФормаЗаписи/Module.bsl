
#Область ОбработчикиСобытийФормы

// Чтение хранилища промпта — только в контексте менеджера записи (extInfo OnReadAtServer):
// у реквизита формы «Запись» поле ПромптОбработкиДокументаХранилище в ПриСозданииНаСервере недоступно.

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	ИАДО_ТекстПромпта = "";
	ХранилищеПромпта = ТекущийОбъект.ПромптОбработкиДокументаХранилище;
	Если ХранилищеПромпта = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		ЗначениеИзХранилища = ХранилищеПромпта.Получить();
	Исключение
		Возврат;
	КонецПопытки;

	Если ЗначениеИзХранилища = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ТипЗнч(ЗначениеИзХранилища) = Тип("Строка") Тогда
		ИАДО_ТекстПромпта = ЗначениеИзХранилища;
	Иначе
		ИАДО_ТекстПромпта = Строка(ЗначениеИзХранилища);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	Если ПустаяСтрока(СокрЛП(ИАДО_ТекстПромпта)) Тогда
		Отказ = Истина;
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Для строки правила укажите текст промпта: он задаёт инструкцию ИИ для данного сочетания вида и тематики и передаётся вместе с текстом выбранного файла.'"),
			Неопределено,
			"ИАДО_ТекстПромпта");
		Возврат;
	КонецЕсли;

	ТекущийОбъект.ПромптОбработкиДокументаХранилище = Новый ХранилищеЗначения(ИАДО_ТекстПромпта);

КонецПроцедуры

#КонецОбласти
