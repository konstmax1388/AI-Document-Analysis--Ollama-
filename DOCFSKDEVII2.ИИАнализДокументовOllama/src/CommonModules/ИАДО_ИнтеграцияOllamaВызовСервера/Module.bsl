
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Проверяет доступность сервера Ollama по базовому URL (запрос GET /api/tags).
//
// Параметры:
//  БазовыйURL - Строка - например "http://localhost:11434" или "http://ollama-server:11434" без завершающего слэша.
//  ТаймаутСек - Число - таймаут HTTP в секундах; при нуле или отрицательном значении используется 30.
//
// Возвращаемое значение:
//  Структура:
//   * Успех - Булево
//   * HTTPКод - Число - код ответа при успешном HTTP-обмене, иначе 0
//   * ТекстОтвета - Строка - тело ответа (ограничено длиной для журналирования)
//   * СообщениеОбОшибке - Строка - краткое описание ошибки для пользователя/журнала
//
Функция ПроверитьДоступность(Знач БазовыйURL, Знач ТаймаутСек = 30) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("HTTPКод", 0);
	Результат.Вставить("ТекстОтвета", "");
	Результат.Вставить("СообщениеОбОшибке", "");

	Контекст = КонтекстHTTPСоединенияOllama(БазовыйURL, ТаймаутСек);
	Если Не Контекст.Успех Тогда
		Результат.СообщениеОбОшибке = Контекст.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;

	ПутьЗапроса = Контекст.ПрефиксПути + "/api/tags";

	Попытка
		Запрос = Новый HTTPЗапрос(ПутьЗапроса);
		Ответ = Контекст.Соединение.Получить(Запрос);

		Результат.HTTPКод = Ответ.КодСостояния;
		Тело = Ответ.ПолучитьТелоКакСтроку("UTF-8");
		Результат.ТекстОтвета = СократитьСтрокуДляЖурнала(Тело, 2000);

		Если Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300 Тогда
			Результат.Успех = Истина;
		Иначе
			Результат.СообщениеОбОшибке = СтрШаблон(
				НСтр("ru = 'Ollama вернул код HTTP %1'"),
				Формат(Ответ.КодСостояния, "ЧГ="));
		КонецЕсли;

	Исключение
		Результат.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Возвращает список имён моделей с сервера Ollama (GET /api/tags, поле models).
//
// Параметры:
//  БазовыйURL - Строка
//  ТаймаутСек - Число
//
// Возвращаемое значение:
//  Структура:
//   * Успех - Булево
//   * HTTPКод - Число
//   * Модели - Массив из Структура: Имя (Строка), РазмерБайт (Число)
//   * СообщениеОбОшибке - Строка
//
Функция СписокМоделейССервера(Знач БазовыйURL, Знач ТаймаутСек = 30) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("HTTPКод", 0);
	Результат.Вставить("Модели", Новый Массив);
	Результат.Вставить("СообщениеОбОшибке", "");

	Контекст = КонтекстHTTPСоединенияOllama(БазовыйURL, ТаймаутСек);
	Если Не Контекст.Успех Тогда
		Результат.СообщениеОбОшибке = Контекст.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;

	ПутьЗапроса = Контекст.ПрефиксПути + "/api/tags";

	Попытка
		Запрос = Новый HTTPЗапрос(ПутьЗапроса);
		Ответ = Контекст.Соединение.Получить(Запрос);

		Результат.HTTPКод = Ответ.КодСостояния;
		Тело = Ответ.ПолучитьТелоКакСтроку("UTF-8");

		Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
			Результат.СообщениеОбОшибке = СтрШаблон(
				НСтр("ru = 'Ollama вернул код HTTP %1'"),
				Формат(Ответ.КодСостояния, "ЧГ="));
			Возврат Результат;
		КонецЕсли;

		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Тело);
		ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON, Истина);

		Если ТипЗнч(ДанныеОтвета) <> Тип("Соответствие") Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'Не удалось разобрать ответ Ollama как JSON-объект'");
			Возврат Результат;
		КонецЕсли;

		ТекстОшибкиAPI = ДанныеОтвета.Получить("error");
		Если ТекстОшибкиAPI <> Неопределено И Не ПустаяСтрока(Строка(ТекстОшибкиAPI)) Тогда
			Результат.СообщениеОбОшибке = Строка(ТекстОшибкиAPI);
			Возврат Результат;
		КонецЕсли;

		МассивМоделей = ДанныеОтвета.Получить("models");
		Если МассивМоделей = Неопределено Или ТипЗнч(МассивМоделей) <> Тип("Массив") Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'В ответе Ollama отсутствует массив models'");
			Возврат Результат;
		КонецЕсли;

		Для Каждого ЭлементМодели Из МассивМоделей Цикл

			Если ТипЗнч(ЭлементМодели) <> Тип("Соответствие") Тогда
				Продолжить;
			КонецЕсли;

			ИмяМодели = ЭлементМодели.Получить("name");
			Если ИмяМодели = Неопределено Или ПустаяСтрока(Строка(ИмяМодели)) Тогда
				ИмяМодели = ЭлементМодели.Получить("model");
			КонецЕсли;

			Если ИмяМодели = Неопределено Или ПустаяСтрока(Строка(ИмяМодели)) Тогда
				Продолжить;
			КонецЕсли;

			РазмерСырой = ЭлементМодели.Получить("size");
			РазмерБайт = 0;
			Если РазмерСырой <> Неопределено Тогда
				Попытка
					РазмерБайт = Число(РазмерСырой);
				Исключение
					РазмерБайт = 0;
				КонецПопытки;
			КонецЕсли;

			СтрокаМодели = Новый Структура("Имя, РазмерБайт", СокрЛП(Строка(ИмяМодели)), РазмерБайт);
			Результат.Модели.Добавить(СтрокаМодели);

		КонецЦикла;

		Результат.Успех = Истина;

	Исключение
		Результат.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Выполняет запрос генерации текста (POST /api/generate, stream = false).
//
// Параметры:
//  БазовыйURL - Строка - базовый адрес Ollama.
//  ТаймаутСек - Число - таймаут HTTP в секундах.
//  ИмяМодели - Строка - зарегистрированное в Ollama имя модели.
//  ТекстПромпта - Строка - пользовательский промпт.
//  СистемныйПромпт - Строка - необязательно; если задан, передаётся в поле system API generate.
//
// Возвращаемое значение:
//  Структура:
//   * Успех - Булево
//   * HTTPКод - Число
//   * ТекстОтвета - Строка - укороченное JSON-тело ответа
//   * ТекстМодели - Строка - значение поля response из ответа Ollama
//   * СообщениеОбОшибке - Строка
//
Функция СгенерироватьОтвет(Знач БазовыйURL, Знач ТаймаутСек, Знач ИмяМодели, Знач ТекстПромпта,
	Знач СистемныйПромпт = "") Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("HTTPКод", 0);
	Результат.Вставить("ТекстОтвета", "");
	Результат.Вставить("ТекстМодели", "");
	Результат.Вставить("СообщениеОбОшибке", "");

	ИмяМодели = СокрЛП(Строка(ИмяМодели));
	Если ПустаяСтрока(ИмяМодели) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не указано имя модели Ollama'");
		Возврат Результат;
	КонецЕсли;

	ТекстПромпта = Строка(ТекстПромпта);

	Контекст = КонтекстHTTPСоединенияOllama(БазовыйURL, ТаймаутСек);
	Если Не Контекст.Успех Тогда
		Результат.СообщениеОбОшибке = Контекст.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;

	ПутьЗапроса = Контекст.ПрефиксПути + "/api/generate";

	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("model", ИмяМодели);
	ТелоЗапроса.Вставить("prompt", ТекстПромпта);
	ТелоЗапроса.Вставить("stream", Ложь);

	СистемныйПромпт = СокрЛП(Строка(СистемныйПромпт));
	Если Не ПустаяСтрока(СистемныйПромпт) Тогда
		ТелоЗапроса.Вставить("system", СистемныйПромпт);
	КонецЕсли;

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ТелоЗапроса);
	СтрокаJSON = ЗаписьJSON.Закрыть();

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	Попытка
		HTTPЗапрос = Новый HTTPЗапрос(ПутьЗапроса, Заголовки);
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);

		Ответ = Контекст.Соединение.ОтправитьДляОбработки(HTTPЗапрос);

		Результат.HTTPКод = Ответ.КодСостояния;
		Тело = Ответ.ПолучитьТелоКакСтроку("UTF-8");
		Результат.ТекстОтвета = СократитьСтрокуДляЖурнала(Тело, 2000);

		Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
			Результат.СообщениеОбОшибке = СтрШаблон(
				НСтр("ru = 'Ollama вернул код HTTP %1'"),
				Формат(Ответ.КодСостояния, "ЧГ="));
			Возврат Результат;
		КонецЕсли;

		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Тело);
		ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON, Истина);

		Если ТипЗнч(ДанныеОтвета) <> Тип("Соответствие") Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'Не удалось разобрать ответ Ollama как JSON-объект'");
			Возврат Результат;
		КонецЕсли;

		ТекстОшибкиAPI = ДанныеОтвета.Получить("error");
		Если ТекстОшибкиAPI <> Неопределено И Не ПустаяСтрока(Строка(ТекстОшибкиAPI)) Тогда
			Результат.СообщениеОбОшибке = Строка(ТекстОшибкиAPI);
			Возврат Результат;
		КонецЕсли;

		ТекстМодели = ДанныеОтвета.Получить("response");
		Если ТекстМодели = Неопределено Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'В ответе Ollama отсутствует поле response'");
			Возврат Результат;
		КонецЕсли;

		Результат.ТекстМодели = Строка(ТекстМодели);
		Результат.Успех = Истина;

	Исключение
		Результат.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Параметры подключения: Успех, Соединение, ПрефиксПути, СообщениеОбОшибке.
Функция КонтекстHTTPСоединенияOllama(Знач БазовыйURL, Знач ТаймаутСек)

	Контекст = Новый Структура;
	Контекст.Вставить("Успех", Ложь);
	Контекст.Вставить("Соединение", Неопределено);
	Контекст.Вставить("ПрефиксПути", "");
	Контекст.Вставить("СообщениеОбОшибке", "");

	БазовыйURL = СокрЛП(Строка(БазовыйURL));
	Если ПустаяСтрока(БазовыйURL) Тогда
		Контекст.СообщениеОбОшибке = НСтр("ru = 'Не задан базовый URL Ollama'");
		Возврат Контекст;
	КонецЕсли;

	Если СтрНайти(НРег(БазовыйURL), "://") = 0 Тогда
		БазовыйURL = "http://" + БазовыйURL;
	КонецЕсли;

	Если ТаймаутСек <= 0 Тогда
		ТаймаутСек = 30;
	КонецЕсли;

	Попытка
		СвойстваПодключения = ОбщегоНазначенияКлиентСервер.СтруктураURI(БазовыйURL);
	Исключение
		Контекст.СообщениеОбОшибке = НСтр("ru = 'Некорректный базовый URL'");
		Возврат Контекст;
	КонецПопытки;

	Если ПустаяСтрока(СвойстваПодключения.Хост) Тогда
		Контекст.СообщениеОбОшибке = НСтр("ru = 'В URL не указан хост'");
		Возврат Контекст;
	КонецЕсли;

	Порт = СвойстваПодключения.Порт;
	Если Порт = Неопределено Тогда
		Если НРег(СвойстваПодключения.Схема) = "https" Тогда
			Порт = 443;
		Иначе
			Порт = 80;
		КонецЕсли;
	КонецЕсли;

	ЗащищенноеСоединение = Неопределено;
	Если НРег(СвойстваПодключения.Схема) = "https" Тогда
		ЗащищенноеСоединение = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
	КонецЕсли;

	ПрефиксПути = "";
	Если Не ПустаяСтрока(СвойстваПодключения.ПутьНаСервере) Тогда
		ПрефиксПути = "/" + СокрЛП(СтрЗаменить(СвойстваПодключения.ПутьНаСервере, "\", "/"));
		Если Прав(ПрефиксПути, 1) = "/" Тогда
			ПрефиксПути = Лев(ПрефиксПути, СтрДлина(ПрефиксПути) - 1);
		КонецЕсли;
	КонецЕсли;

	Попытка
		Соединение = Новый HTTPСоединение(
			СвойстваПодключения.Хост,
			Порт,
			СвойстваПодключения.Логин,
			СвойстваПодключения.Пароль,
			,
			ТаймаутСек,
			ЗащищенноеСоединение);

		Контекст.Соединение = Соединение;
		Контекст.ПрефиксПути = ПрефиксПути;
		Контекст.Успех = Истина;
	Исключение
		Контекст.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Контекст;

КонецФункции

Функция СократитьСтрокуДляЖурнала(Знач Текст, Знач МаксДлина)

	Если СтрДлина(Текст) <= МаксДлина Тогда
		Возврат Текст;
	КонецЕсли;

	Возврат Лев(Текст, МаксДлина) + "...";

КонецФункции

#КонецОбласти

#КонецЕсли
