
#Область ОбработчикиСобытийФормы

&НаСервере
&После("ПриСозданииНаСервере")
Процедура ИАДО_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)

	ИАДО_СоздатьКнопкиАнализаФайлаИИНаФорме();
	ИАДО_ОбновитьСостояниеКнопкиАнализаИИНаСервере();

КонецПроцедуры

&НаСервере
&После("ПослеЗаписиНаСервере")
Процедура ИАДО_ПослеЗаписиНаСервереПосле(ТекущийОбъект, ПараметрыЗаписи)

	ИАДО_ОбновитьСостояниеКнопкиАнализаИИНаСервере();

КонецПроцедуры

&НаСервере
&После("ПриЧтенииНаСервере")
Процедура ИАДО_ПриЧтенииНаСервереПосле(ТекущийОбъект)

	ИАДО_ОбновитьСостояниеКнопкиАнализаИИНаСервере();

КонецПроцедуры

&НаСервере
&После("ПриИзмененииВидаДокумента")
Процедура ИАДО_ПриИзмененииВидаДокументаПосле(ПриСозданииНаСервере = Ложь)

	ИАДО_ОбновитьСостояниеКнопкиАнализаИИНаСервере();

КонецПроцедуры

&НаКлиенте
&После("ВидИТематикаТекстПриИзменении")
Процедура ИАДО_ВидИТематикаТекстПриИзмененииПосле(Элемент)

	ИАДО_ОбновитьСостояниеКнопкиАнализаИИНаСервере();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Команда и кнопки добавляются программно: в шапке (ГруппаОсновнаяКомПанель / запасные варианты) и на панели «ФайлыКоманднаяПанель».
// В Form.form расширения не дублируются элементы с теми же идентификаторами, что в типовой форме — иначе при слиянии подменяется
// таблица «Файлы» и ломается размещение реквизитов (группы ГруппаЛевоДопПарам и т.п.).

&НаСервере
Процедура ИАДО_СоздатьКнопкиАнализаФайлаИИНаФорме()

	ИАДО_ОбеспечитьКомандуАнализаФайлаИИ();

	Если Элементы.Найти("ИАДО_КнопкаАнализФайлаИИ") = Неопределено Тогда

		РодительВШапке = ИАДО_РодительКнопкиИИВШапкеДокумента();
		Если РодительВШапке <> Неопределено Тогда
			КнопкаШапка = Элементы.Добавить("ИАДО_КнопкаАнализФайлаИИ", Тип("КнопкаФормы"), РодительВШапке);
			КнопкаШапка.ИмяКоманды = "ИАДО_АнализТекущегоФайлаИИ";
			КнопкаШапка.ВажностьПриОтображении = ВажностьПриОтображении.Высокая;
			ЭлементПередКоторымВставить = Элементы.Найти("ФормаЗаписатьИЗакрыть");
			Если ЭлементПередКоторымВставить <> Неопределено
				И РодительВШапке = ЭлементПередКоторымВставить.Родитель Тогда
				Элементы.Переместить(КнопкаШапка, РодительВШапке, ЭлементПередКоторымВставить);
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;

	Если Элементы.Найти("ИАДО_КнопкаАнализФайлаИИВПанелиФайлов") = Неопределено Тогда

		ПанельФайлов = Элементы.Найти("ФайлыКоманднаяПанель");
		Если ПанельФайлов <> Неопределено Тогда
			КнопкаПанельФайлов = Элементы.Добавить("ИАДО_КнопкаАнализФайлаИИВПанелиФайлов", Тип("КнопкаФормы"), ПанельФайлов);
			КнопкаПанельФайлов.ИмяКоманды = "ИАДО_АнализТекущегоФайлаИИ";
			КнопкаПанельФайлов.Заголовок = НСтр("ru = 'ИИ: проанализировать'");
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ИАДО_ОбеспечитьКомандуАнализаФайлаИИ()

	Если Команды.Найти("ИАДО_АнализТекущегоФайлаИИ") <> Неопределено Тогда
		Возврат;
	КонецЕсли;

	КомандаАнализа = Команды.Добавить("ИАДО_АнализТекущегоФайлаИИ");
	КомандаАнализа.Действие = "ИАДО_АнализТекущегоФайлаИИ";
	КомандаАнализа.Заголовок = НСтр("ru = 'ИИ: проанализировать файл'");
	КомандаАнализа.Подсказка =
		НСтр("ru = 'Отправить в модель Ollama текст файла вместе с промптом из правила для вида и тематики документа. Если файлов несколько — откроется выбор.'");
	КомандаАнализа.Отображение = ОтображениеКнопки.Текст;

КонецПроцедуры

&НаСервере
Функция ИАДО_РодительКнопкиИИВШапкеДокумента()

	ГруппаИАДО = Элементы.Найти("ИАДО_КомандыАнализаДокумента");
	Если ГруппаИАДО <> Неопределено И ГруппаИАДО.Родитель <> Неопределено Тогда
		Возврат ГруппаИАДО.Родитель;
	КонецЕсли;

	РодительКнопки = Элементы.Найти("ГруппаОсновнаяКомПанель");
	Если РодительКнопки = Неопределено Тогда
		РодительКнопки = Элементы.Найти("ГруппаКомПанели");
	КонецЕсли;
	Если РодительКнопки = Неопределено Тогда
		ЭлементЗаписать = Элементы.Найти("ФормаЗаписать");
		Если ЭлементЗаписать <> Неопределено Тогда
			РодительКнопки = ЭлементЗаписать.Родитель;
		КонецЕсли;
	КонецЕсли;

	Возврат РодительКнопки;

КонецФункции

&НаСервере
Процедура ИАДО_ОбновитьСостояниеКнопкиАнализаИИНаСервере()

	ПравилоИПромптНастроены = ИАДО_НастройкиАнализаИИВызовСервера.ЕстьПравилоДляПередачиВИИПоВидуИТематике(
		Объект.ВидДокумента,
		Объект.Тематика);

	ДоступностьКнопки =
		ПравилоИПромптНастроены
		И ЗначениеЗаполнено(Объект.Ссылка);

	ИАДО_ПрименитьСостояниеКнопкеАнализаИИ("ИАДО_КнопкаАнализФайлаИИ", ДоступностьКнопки);
	ИАДО_ПрименитьСостояниеКнопкеАнализаИИ("ИАДО_КнопкаАнализФайлаИИВПанелиФайлов", ДоступностьКнопки);

КонецПроцедуры

&НаСервере
Процедура ИАДО_ПрименитьСостояниеКнопкеАнализаИИ(Знач ИмяЭлемента, Знач ДоступностьКнопки)

	КнопкаАнализа = Элементы.Найти(ИмяЭлемента);
	Если КнопкаАнализа = Неопределено Тогда
		Возврат;
	КонецЕсли;

	КнопкаАнализа.Видимость = Истина;
	КнопкаАнализа.Доступность = ДоступностьКнопки;

КонецПроцедуры

&НаСервере
Функция ИАДО_ЕстьПравилоДляТекущегоВидаДокументаНаФорме()

	Возврат ИАДО_НастройкиАнализаИИВызовСервера.ЕстьПравилоДляПередачиВИИПоВидуИТематике(Объект.ВидДокумента, Объект.Тематика);

КонецФункции

&НаСервере
Функция ИАДО_СписокФайловДокументаДляАнализаИИНаСервере(Знач ДокументСсылка)

	Возврат ИАДО_НастройкиАнализаИИВызовСервера.СписокФайловДокументаДляАнализаИИ(ДокументСсылка);

КонецФункции

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ИАДО_АнализТекущегоФайлаИИ(Команда)

	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Запишите документ, затем выполните анализ файла.'"));
		Возврат;
	КонецЕсли;

	Если Не ИАДО_ЕстьПравилоДляТекущегоВидаДокументаНаФорме() Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для текущего вида и тематики нет активной строки в регистре «Правила выбора эксперта» с заполненным промптом.'"));
		Возврат;
	КонецЕсли;

	СписокФайлов = ИАДО_СписокФайловДокументаДляАнализаИИНаСервере(Объект.Ссылка);
	Если СписокФайлов.Количество() = 0 Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'К документу не прикреплено файлов для анализа (справочник «Файлы», владелец — этот документ).'"));
		Возврат;
	КонецЕсли;

	Если СписокФайлов.Количество() = 1 Тогда
		ИАДО_ЗапуститьАнализФайлаИИНаКлиенте(СписокФайлов[0].Файл);
		Возврат;
	КонецЕсли;

	ТекущиеДанныеФайла = Элементы.Файлы.ТекущиеДанные;
	Если ТекущиеДанныеФайла <> Неопределено И ЗначениеЗаполнено(ТекущиеДанныеФайла.Ссылка) Тогда
		Для Каждого СтрокаСписка Из СписокФайлов Цикл
			Если СтрокаСписка.Файл = ТекущиеДанныеФайла.Ссылка Тогда
				ИАДО_ЗапуститьАнализФайлаИИНаКлиенте(ТекущиеДанныеФайла.Ссылка);
				Возврат;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	СписокВыбора = Новый СписокЗначений;
	Для Каждого СтрокаСписка Из СписокФайлов Цикл
		СписокВыбора.Добавить(СтрокаСписка.Файл, СтрокаСписка.Представление);
	КонецЦикла;

	ЭлементДляСписка = Элементы.Найти("Файлы");
	Если ЭлементДляСписка = Неопределено Тогда
		ЭлементДляСписка = Элементы.Найти("ИАДО_КнопкаАнализФайлаИИВПанелиФайлов");
	КонецЕсли;
	Если ЭлементДляСписка = Неопределено Тогда
		ЭлементДляСписка = Элементы.Найти("ИАДО_КнопкаАнализФайлаИИ");
	КонецЕсли;

	Оповещение = Новый ОписаниеОповещения("ИАДО_ПослеВыбораФайлаДляАнализаИИ", ЭтотОбъект);
	ПоказатьВыборИзСписка(Оповещение, СписокВыбора, ЭлементДляСписка);

КонецПроцедуры

&НаКлиенте
Процедура ИАДО_ПослеВыбораФайлаДляАнализаИИ(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт

	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИАДО_ЗапуститьАнализФайлаИИНаКлиенте(ВыбранныйЭлемент.Значение);

КонецПроцедуры

&НаКлиенте
Процедура ИАДО_ЗапуститьАнализФайлаИИНаКлиенте(ФайлСсылка)

	ПараметрыОперации = Новый Структура;
	ПараметрыОперации.Вставить("ИмяОперации", "АнализФайла");
	ПараметрыОперации.Вставить("Документ", Объект.Ссылка);
	ПараметрыОперации.Вставить("Файл", ФайлСсылка);

	Оповещение = Новый ОписаниеОповещения("ИАДО_ПослеФоновогоАнализаФайлаИИ", ЭтотОбъект);
	ИАДО_ИнтеграцияИИКлиент.ВыполнитьОперациюИИСОжиданием(Оповещение, ЭтотОбъект, ПараметрыОперации);

КонецПроцедуры

&НаКлиенте
Процедура ИАДО_ПослеФоновогоАнализаФайлаИИ(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Свойство("Статус") Тогда
		Если Результат.Статус = "Отменено" Тогда
			Возврат;
		ИначеЕсли Результат.Статус = "Ошибка" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
			Возврат;
		КонецЕсли;
	КонецЕсли;

	ДанныеОперации = Неопределено;
	Если Результат.Свойство("АдресРезультата") И ЭтоАдресВременногоХранилища(Результат.АдресРезультата) Тогда
		ДанныеОперации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	КонецЕсли;

	Если ДанныеОперации = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ДанныеОперации.Свойство("Успех") И ДанныеОперации.Успех Тогда
		ТекстОтвета = "";
		Если ДанныеОперации.Свойство("ТекстМодели") Тогда
			ТекстОтвета = ДанныеОперации.ТекстМодели;
		КонецЕсли;
		ПоказатьЗначение(, ТекстОтвета);
	Иначе
		ТекстОшибкиДляПользователя = "";
		Если ДанныеОперации.Свойство("Сообщение") Тогда
			ТекстОшибкиДляПользователя = ДанныеОперации.Сообщение;
		КонецЕсли;
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибкиДляПользователя);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
