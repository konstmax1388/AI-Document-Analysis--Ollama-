
#Область ПрограммныйИнтерфейс

// Запускает серверную операцию ИИ в фоне и показывает ожидание (БСП «Длительные операции»).
//
// Параметры:
//  ОповещениеОЗавершении - ОписаниеОповещения - получает результат см. ВыполнитьОперациюИИВФоне.
//  ФормаВладелец - ФормаКлиентскогоПриложения, Неопределено
//  ПараметрыОперации - Структура - см. ИАДО_ИнтеграцияИИВызовСервера.НачатьОперациюИИВФоне
//
Процедура ВыполнитьОперациюИИСОжиданием(ОповещениеОЗавершении, ФормаВладелец, ПараметрыОперации) Экспорт

	ИдФормы = Неопределено;
	Если ФормаВладелец <> Неопределено Тогда
		ИдФормы = ФормаВладелец.УникальныйИдентификатор;
	КонецЕсли;

	ДлительнаяОперация = ИАДО_ИнтеграцияИИВызовСервера.НачатьОперациюИИВФоне(ПараметрыОперации, ИдФормы);

	Если ДлительнаяОперация = Неопределено Тогда
		ВыполнитьОбработкуОповещения(ОповещениеОЗавершении, Неопределено);
		Возврат;
	КонецЕсли;

	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ФормаВладелец);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'ИИ (Ollama): ожидание ответа модели...'");
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);

КонецПроцедуры

#КонецОбласти
