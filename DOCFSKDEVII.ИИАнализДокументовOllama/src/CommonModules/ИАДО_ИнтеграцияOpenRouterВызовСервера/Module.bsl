#Область ПрограммныйИнтерфейс

// Проверка доступности API (GET …/v1/models с заголовком Authorization).
//
// Параметры:
//  БазовыйURL - Строка - например https://openrouter.ai/api/v1
//  ТаймаутСек - Число
//  КлючAPI - Строка - Bearer-токен без префикса «Bearer »
//
// Возвращаемое значение:
//  Структура - см. ИАДО_ИнтеграцияOllamaВызовСервера.ПроверитьДоступность (те же поля)
//
Функция ПроверитьДоступность(Знач БазовыйURL, Знач ТаймаутСек, Знач КлючAPI) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("HTTPКод", 0);
	Результат.Вставить("ТекстОтвета", "");
	Результат.Вставить("СообщениеОбОшибке", "");

	КлючAPI = СокрЛП(Строка(КлючAPI));
	Если ПустаяСтрока(КлючAPI) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не задан ключ API OpenRouter (константа «OpenRouter: ключ API»).'");
		Возврат Результат;
	КонецЕсли;

	Контекст = КонтекстHTTPСоединенияOpenRouter(БазовыйURL, ТаймаутСек);
	Если Не Контекст.Успех Тогда
		Результат.СообщениеОбОшибке = Контекст.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;

	ПутьЗапроса = Контекст.ПрефиксПути + "/models";

	Попытка
		Запрос = Новый HTTPЗапрос(ПутьЗапроса, ЗаголовкиOpenRouter(КлючAPI));
		Ответ = Контекст.Соединение.Получить(Запрос);

		Результат.HTTPКод = Ответ.КодСостояния;
		Тело = Ответ.ПолучитьТелоКакСтроку("UTF-8");
		Результат.ТекстОтвета = СократитьСтрокуДляЖурнала(Тело, 2000);

		Если Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300 Тогда
			Результат.Успех = Истина;
		Иначе
			Результат.СообщениеОбОшибке = СтрШаблон(
				НСтр("ru = 'OpenRouter вернул код HTTP %1'"),
				Формат(Ответ.КодСостояния, "ЧГ="));
		КонецЕсли;

	Исключение
		Результат.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Генерация ответа (POST …/v1/chat/completions).
//
// Параметры:
//  БазовыйURL, ТаймаутСек, ИмяМодели, ТекстПромпта, СистемныйПромпт - аналогично Ollama
//  КлючAPI - Строка
//
// Возвращаемое значение:
//  Структура - те же ключи, что у ИАДО_ИнтеграцияOllamaВызовСервера.СгенерироватьОтвет
//
Функция СгенерироватьОтвет(Знач БазовыйURL, Знач ТаймаутСек, Знач ИмяМодели, Знач ТекстПромпта,
	Знач СистемныйПромпт = "", Знач КлючAPI = "") Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("HTTPКод", 0);
	Результат.Вставить("ТекстОтвета", "");
	Результат.Вставить("ТекстМодели", "");
	Результат.Вставить("СообщениеОбОшибке", "");

	КлючAPI = СокрЛП(Строка(КлючAPI));
	Если ПустаяСтрока(КлючAPI) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не задан ключ API OpenRouter'");
		Возврат Результат;
	КонецЕсли;

	ИмяМодели = СокрЛП(Строка(ИмяМодели));
	Если ПустаяСтрока(ИмяМодели) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не указано имя модели OpenRouter'");
		Возврат Результат;
	КонецЕсли;

	ТекстПромпта = Строка(ТекстПромпта);

	Контекст = КонтекстHTTPСоединенияOpenRouter(БазовыйURL, ТаймаутСек);
	Если Не Контекст.Успех Тогда
		Результат.СообщениеОбОшибке = Контекст.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;

	ПутьЗапроса = Контекст.ПрефиксПути + "/chat/completions";

	Сообщения = Новый Массив;
	СистемныйПромпт = СокрЛП(Строка(СистемныйПромпт));
	Если Не ПустаяСтрока(СистемныйПромпт) Тогда
		Сообщения.Добавить(Новый Структура("role, content", "system", СистемныйПромпт));
	КонецЕсли;
	Сообщения.Добавить(Новый Структура("role, content", "user", ТекстПромпта));

	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("model", ИмяМодели);
	ТелоЗапроса.Вставить("messages", Сообщения);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ТелоЗапроса);
	СтрокаJSON = ЗаписьJSON.Закрыть();

	Заголовки = ЗаголовкиOpenRouter(КлючAPI);
	Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	Попытка
		HTTPЗапрос = Новый HTTPЗапрос(ПутьЗапроса, Заголовки);
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);

		Ответ = Контекст.Соединение.ОтправитьДляОбработки(HTTPЗапрос);

		Результат.HTTPКод = Ответ.КодСостояния;
		Тело = Ответ.ПолучитьТелоКакСтроку("UTF-8");
		Результат.ТекстОтвета = СократитьСтрокуДляЖурнала(Тело, 2000);

		Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
			Результат.СообщениеОбОшибке = СтрШаблон(
				НСтр("ru = 'OpenRouter вернул код HTTP %1'"),
				Формат(Ответ.КодСостояния, "ЧГ="));
			ТекстОшибкиИзТела = ТекстОшибкиOpenRouterИзJSON(Тело);
			Если Не ПустаяСтрока(ТекстОшибкиИзТела) Тогда
				Результат.СообщениеОбОшибке = Результат.СообщениеОбОшибке + ": " + ТекстОшибкиИзТела;
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;

		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Тело);
		ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON, Истина);

		Если ТипЗнч(ДанныеОтвета) <> Тип("Соответствие") Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'Не удалось разобрать ответ OpenRouter как JSON-объект'");
			Возврат Результат;
		КонецЕсли;

		ТекстОшибкиКорень = ТекстОшибкиOpenRouterИзСоответствия(ДанныеОтвета);
		Если Не ПустаяСтрока(ТекстОшибкиКорень) Тогда
			Результат.СообщениеОбОшибке = ТекстОшибкиКорень;
			Возврат Результат;
		КонецЕсли;

		ВариантыВыбора = ДанныеОтвета.Получить("choices");
		Если ВариантыВыбора = Неопределено Или ТипЗнч(ВариантыВыбора) <> Тип("Массив") Или ВариантыВыбора.Количество() = 0 Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'В ответе OpenRouter нет массива choices или он пуст'");
			Возврат Результат;
		КонецЕсли;

		ПервыйВыбор = ВариантыВыбора[0];
		Если ТипЗнч(ПервыйВыбор) <> Тип("Соответствие") Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'Некорректный элемент choices[0] в ответе OpenRouter'");
			Возврат Результат;
		КонецЕсли;

		СообщениеАссистента = ПервыйВыбор.Получить("message");
		Если СообщениеАссистента = Неопределено Или ТипЗнч(СообщениеАссистента) <> Тип("Соответствие") Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'В ответе OpenRouter отсутствует message'");
			Возврат Результат;
		КонецЕсли;

		Контент = СообщениеАссистента.Получить("content");
		Если Контент = Неопределено Тогда
			Результат.СообщениеОбОшибке = НСтр("ru = 'В ответе OpenRouter отсутствует content'");
			Возврат Результат;
		КонецЕсли;

		Результат.ТекстМодели = Строка(Контент);
		Результат.Успех = Истина;

	Исключение
		Результат.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЗаголовкиOpenRouter(Знач КлючAPI)

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Authorization", "Bearer " + СокрЛП(Строка(КлючAPI)));
	Заголовки.Вставить("HTTP-Referer", "https://localhost");
	Заголовки.Вставить("X-Title", "1C IA DO Ollama Extension");
	Возврат Заголовки;

КонецФункции

Функция КонтекстHTTPСоединенияOpenRouter(Знач БазовыйURL, Знач ТаймаутСек)

	Контекст = Новый Структура;
	Контекст.Вставить("Успех", Ложь);
	Контекст.Вставить("Соединение", Неопределено);
	Контекст.Вставить("ПрефиксПути", "");
	Контекст.Вставить("СообщениеОбОшибке", "");

	БазовыйURL = СокрЛП(Строка(БазовыйURL));
	Если ПустаяСтрока(БазовыйURL) Тогда
		БазовыйURL = "https://openrouter.ai/api/v1";
	КонецЕсли;

	Если СтрНайти(НРег(БазовыйURL), "://") = 0 Тогда
		БазовыйURL = "https://" + БазовыйURL;
	КонецЕсли;

	Если ТаймаутСек <= 0 Тогда
		ТаймаутСек = 30;
	КонецЕсли;

	Попытка
		СвойстваПодключения = ОбщегоНазначенияКлиентСервер.СтруктураURI(БазовыйURL);
	Исключение
		Контекст.СообщениеОбОшибке = НСтр("ru = 'Некорректный базовый URL OpenRouter'");
		Возврат Контекст;
	КонецПопытки;

	Если ПустаяСтрока(СвойстваПодключения.Хост) Тогда
		Контекст.СообщениеОбОшибке = НСтр("ru = 'В URL не указан хост'");
		Возврат Контекст;
	КонецЕсли;

	Порт = СвойстваПодключения.Порт;
	Если Порт = Неопределено Тогда
		Если НРег(СвойстваПодключения.Схема) = "https" Тогда
			Порт = 443;
		Иначе
			Порт = 80;
		КонецЕсли;
	КонецЕсли;

	ЗащищенноеСоединение = Неопределено;
	Если НРег(СвойстваПодключения.Схема) = "https" Тогда
		ЗащищенноеСоединение = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
	КонецЕсли;

	ПрефиксПути = "";
	Если Не ПустаяСтрока(СвойстваПодключения.ПутьНаСервере) Тогда
		ПрефиксПути = "/" + СокрЛП(СтрЗаменить(СвойстваПодключения.ПутьНаСервере, "\", "/"));
		Если Прав(ПрефиксПути, 1) = "/" Тогда
			ПрефиксПути = Лев(ПрефиксПути, СтрДлина(ПрефиксПути) - 1);
		КонецЕсли;
	КонецЕсли;

	Попытка
		Соединение = Новый HTTPСоединение(
			СвойстваПодключения.Хост,
			Порт,
			СвойстваПодключения.Логин,
			СвойстваПодключения.Пароль,
			,
			ТаймаутСек,
			ЗащищенноеСоединение);

		Контекст.Соединение = Соединение;
		Контекст.ПрефиксПути = ПрефиксПути;
		Контекст.Успех = Истина;
	Исключение
		Контекст.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Контекст;

КонецФункции

Функция ТекстОшибкиOpenRouterИзJSON(Знач Тело)

	Если ПустаяСтрока(СокрЛП(Тело)) Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Тело);
		Данные = ПрочитатьJSON(ЧтениеJSON, Истина);
		Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
			Возврат ТекстОшибкиOpenRouterИзСоответствия(Данные);
		КонецЕсли;
	Исключение
		Возврат "";
	КонецПопытки;

	Возврат "";

КонецФункции

Функция ТекстОшибкиOpenRouterИзСоответствия(Знач Данные)

	УзелОшибки = Данные.Получить("error");
	Если УзелОшибки = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Если ТипЗнч(УзелОшибки) = Тип("Соответствие") Тогда
		Текст = УзелОшибки.Получить("message");
		Если Текст <> Неопределено Тогда
			Возврат Строка(Текст);
		КонецЕсли;
	Иначе
		Возврат Строка(УзелОшибки);
	КонецЕсли;

	Возврат "";

КонецФункции

Функция СократитьСтрокуДляЖурнала(Знач Текст, Знач МаксДлина)

	Если СтрДлина(Текст) <= МаксДлина Тогда
		Возврат Текст;
	КонецЕсли;

	Возврат Лев(Текст, МаксДлина) + "...";

КонецФункции

#КонецОбласти

#КонецЕсли
