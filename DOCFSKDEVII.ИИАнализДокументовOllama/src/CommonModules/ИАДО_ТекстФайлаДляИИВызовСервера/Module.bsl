
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Готовит текст текущей версии файла для передачи в языковую модель.
// Сначала читается регистр сведений «Тексты версий файлов»; если текста нет — выполняется
// серверное извлечение через типовые средства (аналогично извлечению текста файлов).
// Модели Ollama (в т.ч. DeepSeek-R1) получают текст; двоичные файлы без текста в модель не передаются.
//
// Параметры:
//  ФайлСсылка - СправочникСсылка.Файлы
//
// Возвращаемое значение:
//  Структура:
//   * ТекстДляПромпта - Строка
//   * ИсточникТекста - Строка - см. ИсточникТекстаРегистр(), ИсточникТекстаИзвлечение()
//   * ДоступенДляМодели - Булево
//   * СообщениеОбОшибке - Строка - заполнено при ДоступенДляМодели = Ложь
//   * СтатусИзвлечения - ПеречислениеСсылка.СтатусыИзвлеченияТекстаФайлов, Неопределено
//
Функция ПодготовитьТекстВерсииФайлаДляМодели(Знач ФайлСсылка) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("ТекстДляПромпта", "");
	Результат.Вставить("ИсточникТекста", "");
	Результат.Вставить("ДоступенДляМодели", Ложь);
	Результат.Вставить("СообщениеОбОшибке", "");
	Результат.Вставить("СтатусИзвлечения", Неопределено);

	Если Не ЗначениеЗаполнено(ФайлСсылка) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Не указан файл'");
		Возврат Результат;
	КонецЕсли;

	РеквизитыФайла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ФайлСсылка, "ТекущаяВерсия, ТекущаяВерсияРасширение");
	ВерсияФайла = РеквизитыФайла.ТекущаяВерсия;

	Если Не ЗначениеЗаполнено(ВерсияФайла) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'У файла не заполнена текущая версия'");
		Возврат Результат;
	КонецЕсли;

	ТекстИзРегистра = ТекстИзРегистраТекстовВерсий(ВерсияФайла);
	Если Не ПустаяСтрока(ТекстИзРегистра) Тогда
		Результат.ТекстДляПромпта = ТекстИзРегистра;
		Результат.ИсточникТекста = ИсточникТекстаРегистр();
		Результат.ДоступенДляМодели = Истина;
		Возврат Результат;
	КонецЕсли;

	ДвоичныеДанные = РаботаСФайламиВызовСервера.ПолучитьДвоичныеДанныеФайла(ФайлСсылка);
	РасширениеНорм = НормализоватьРасширениеДляИзвлеченияТекста(РеквизитыФайла.ТекущаяВерсияРасширение);
	Если ПустаяСтрока(РасширениеНорм) Тогда
		РасширениеНорм = РасширениеПоСигнатуреДвоичныхДанных(ДвоичныеДанные);
	КонецЕсли;

	ТекстИзвлечения = "";
	СтатусИзвлечения = ПрисоединенныеФайлыСлужебный.ИзвлечьТекст(ДвоичныеДанные, РасширениеНорм, ТекстИзвлечения);
	Результат.СтатусИзвлечения = СтатусИзвлечения;

	Если СтатусИзвлечения = Перечисления.СтатусыИзвлеченияТекстаФайлов.Извлечен Тогда
		Результат.ТекстДляПромпта = СокрЛП(Строка(ТекстИзвлечения));
		Если ПустаяСтрока(Результат.ТекстДляПромпта) Тогда
			Результат.СообщениеОбОшибке = ТекстЕслиТекстНедоступен(РасширениеНорм);
		Иначе
			Результат.ИсточникТекста = ИсточникТекстаИзвлечение();
			Результат.ДоступенДляМодели = Истина;
		КонецЕсли;

	ИначеЕсли СтатусИзвлечения = Перечисления.СтатусыИзвлеченияТекстаФайлов.НеИзвлечен Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'Текст из файла не извлечён автоматически: извлечение на сервере отключено или файлы данного типа не поддерживаются. Заполните регистр «Тексты версий файлов» (распознавание/извлечение в карточке файла).'");

	Иначе
		Результат.СообщениеОбОшибке = ТекстЕслиТекстНедоступен(РасширениеНорм);

	КонецЕсли;

	Возврат Результат;

КонецФункции

// Идентификатор источника: текст из регистра «Тексты версий файлов».
//
Функция ИсточникТекстаРегистр() Экспорт
	Возврат "РегистрТекстовВерсий";
КонецФункции

// Идентификатор источника: извлечение на сервере 1С при отсутствии записи в регистре.
//
Функция ИсточникТекстаИзвлечение() Экспорт
	Возврат "ИзвлечениеСервера1С";
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЕслиТекстНедоступен(Знач РасширениеФайла = "")

	Текст = НСтр("ru = 'Нет распознанного или извлечённого текста для передачи в модель. Модели в Ollama (в т.ч. DeepSeek-R1) работают с текстом из промпта, а не с двоичным содержимым файла: настройте извлечение/распознавание в Документообороте и дождитесь заполнения регистра «Тексты версий файлов».'");

	Если НРег(СокрЛП(РасширениеФайла)) = "pdf" Тогда
		Текст = Текст + Символы.ПС
			+ НСтр("ru = 'PDF без текстового слоя (скан изображением) штатным ИзвлечениеТекста не читается — выполните распознавание в Документообороте; итог попадёт в регистр «Тексты версий файлов», после чего анализ ИИ станет доступен.'");
	КонецЕсли;

	Возврат Текст;

КонецФункции

Функция НормализоватьРасширениеДляИзвлеченияТекста(Знач РасширениеИзМетаданных)

	Результат = СокрЛП(Строка(РасширениеИзМетаданных));
	Результат = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(Результат);

	Возврат НРег(Результат);

КонецФункции

Функция РасширениеПоСигнатуреДвоичныхДанных(Знач ДвоичныеДанные)

	Если ДвоичныеДанные = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Если ДвоичныеДанные.Размер() < 4 Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		ЧтениеДанных = Новый ЧтениеДанных(ДвоичныеДанные);
		Буфер = ЧтениеДанных.ПрочитатьВБуферДвоичныхДанных(4);
		ЧтениеДанных.Закрыть();
	Исключение
		Возврат "";
	КонецПопытки;

	НачалоФайла = ПолучитьСтрокуИзБуфераДвоичныхДанных(Буфер);
	Если НачалоФайла = "%PDF" Тогда
		Возврат "pdf";
	КонецЕсли;

	Возврат "";

КонецФункции

Функция ТекстИзРегистраТекстовВерсий(Знач ВерсияФайла)

	ХранилищеТекста = РегистрыСведений.ТекстыВерсийФайлов.ПолучитьТекстХранилище(ВерсияФайла);
	Если ХранилищеТекста = Неопределено Тогда
		Возврат ТекстВерсииИзРегистраПоИзвлеченномуИРаспознанному(ВерсияФайла);
	КонецЕсли;

	Попытка
		ТекстВерсии = ХранилищеТекста.Получить();
	Исключение
		Возврат ТекстВерсииИзРегистраПоИзвлеченномуИРаспознанному(ВерсияФайла);
	КонецПопытки;

	ТекстПоРесурсуХранилище = СокрЛП(Строка(ТекстВерсии));
	Если Не ПустаяСтрока(ТекстПоРесурсуХранилище) Тогда
		Возврат ТекстПоРесурсуХранилище;
	КонецЕсли;

	Возврат ТекстВерсииИзРегистраПоИзвлеченномуИРаспознанному(ВерсияФайла);

КонецФункции

Функция ТекстВерсииИзРегистраПоИзвлеченномуИРаспознанному(Знач ВерсияФайла)

	Набор = РегистрыСведений.ТекстыВерсийФайлов.СоздатьНаборЗаписей();
	Набор.Отбор.Версия.Установить(ВерсияФайла);
	Набор.Прочитать();

	Если Набор.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;

	ЗаписьРегистра = Набор[0];
	ИзвлеченныйТекст = "";
	РаспознанныйТекст = "";

	Попытка
		ИзвлеченныйТекст = Строка(ЗаписьРегистра.ИзвлеченныйТекст.Получить());
	Исключение
		ИзвлеченныйТекст = "";
	КонецПопытки;

	Попытка
		РаспознанныйТекст = Строка(ЗаписьРегистра.РаспознанныйТекст.Получить());
	Исключение
		РаспознанныйТекст = "";
	КонецПопытки;

	Текст = СокрЛП(ИзвлеченныйТекст);

	Если Не ПустаяСтрока(СокрЛП(РаспознанныйТекст)) Тогда

		Если Не ПустаяСтрока(Текст) Тогда
			Текст = Текст + " " + Символы.ВК + Символы.ПС;
		КонецЕсли;

		Текст = Текст + СокрЛП(РаспознанныйТекст);

	КонецЕсли;

	Возврат СокрЛП(Текст);

КонецФункции

#КонецОбласти

#КонецЕсли
