#Область ПрограммныйИнтерфейс

// Записывает строку в регистр ИАДО_ЖурналОбращенийКИИ.
//
// Параметры:
//  ПараметрыЗаписи - Структура - обязательные ключи: ВидОперации (Строка), Успешно (Булево), Сообщение (Строка).
//   Необязательные: HTTPКод, ИмяМодели, ИсточникТекстаФайла, ТекстОтветаКратко,
//   Документ, Файл, Детали (произвольное значение для помещения в хранилище).
//
Процедура ДобавитьЗапись(Знач ПараметрыЗаписи) Экспорт

	НаборЗаписей = РегистрыСведений.ИАДО_ЖурналОбращенийКИИ.СоздатьНаборЗаписей();
	Запись = НаборЗаписей.Добавить();
	// Универсальные дата/время снижают риск совпадения ключа при пакетных записях и упорядочивание журнала.
	Запись.ДатаВремя = ТекущаяУниверсальнаяДата();
	Запись.Идентификатор = Строка(Новый УникальныйИдентификатор());

	Запись.ВидОперации = Строка(ПараметрыЗаписи.ВидОперации);
	Запись.Успешно = ПараметрыЗаписи.Успешно;
	Запись.Сообщение = Лев(Строка(ПараметрыЗаписи.Сообщение), 1024);

	Запись.HTTPКод = 0;
	Если ПараметрыЗаписи.Свойство("HTTPКод") Тогда
		Запись.HTTPКод = ПараметрыЗаписи.HTTPКод;
	КонецЕсли;

	Запись.ИмяМодели = "";
	Если ПараметрыЗаписи.Свойство("ИмяМодели") Тогда
		Запись.ИмяМодели = Строка(ПараметрыЗаписи.ИмяМодели);
	КонецЕсли;

	Запись.ИсточникТекстаФайла = "";
	Если ПараметрыЗаписи.Свойство("ИсточникТекстаФайла") Тогда
		Запись.ИсточникТекстаФайла = Строка(ПараметрыЗаписи.ИсточникТекстаФайла);
	КонецЕсли;

	Запись.ТекстОтветаКратко = "";
	Если ПараметрыЗаписи.Свойство("ТекстОтветаКратко") Тогда
		Запись.ТекстОтветаКратко = Лев(Строка(ПараметрыЗаписи.ТекстОтветаКратко), 1024);
	КонецЕсли;

	Если ПараметрыЗаписи.Свойство("Документ") Тогда
		Запись.Документ = ПараметрыЗаписи.Документ;
	КонецЕсли;

	Если ПараметрыЗаписи.Свойство("Файл") Тогда
		Запись.Файл = ПараметрыЗаписи.Файл;
	КонецЕсли;

	Попытка
		Запись.Пользователь = ПользователиКлиентСервер.ТекущийПользователь();
	Исключение
		Запись.Пользователь = Справочники.Пользователи.ПустаяСсылка();
	КонецПопытки;

	Если ПараметрыЗаписи.Свойство("Детали") И ПараметрыЗаписи.Детали <> Неопределено Тогда
		Запись.ДеталиХранилище = Новый ХранилищеЗначения(ПараметрыЗаписи.Детали);
	КонецЕсли;

	НаборЗаписей.Записать();

КонецПроцедуры

#КонецОбласти

#КонецЕсли
