
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	РезультатТеста = ИАДО_НастройкиАнализаИИВызовСервера.ТестПодключенияСПромптомПоКонстантам(Истина);

	Если РезультатТеста.Успех Тогда
		ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Подключение успешно. Ответ модели:%1%2'"),
			Символы.ПС,
			РезультатТеста.ТекстМодели);
	Иначе
		ТекстСообщения = РезультатТеста.ТекстДляПользователя;
	КонецЕсли;

	ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);

КонецПроцедуры

#КонецОбласти
